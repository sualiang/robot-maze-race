/* pages/help/help.wxss - 发起者助力管理页 */

/* ===== 加载/空状态 ===== */
.loading-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
  padding: var(--space-xl);
}

.loading-text {
  font-size: var(--font-base);
  color: var(--color-text-light);
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: var(--space-base);
}

.empty-title {
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  margin-bottom: var(--space-lg);
}

.btn-create-help {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #ffffff;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.btn-create-help::after {
  border: none;
}

/* ===== 进度卡片 ===== */
.progress-card {
  padding: var(--space-lg);
  margin-bottom: var(--space-base);
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}

.progress-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.progress-card-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
}

.progress-card-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.progress-card-badge.active {
  color: #e94560;
  background: rgba(233,69,96,0.15);
}

.progress-card-badge.completed {
  color: #07c160;
  background: rgba(7,193,96,0.15);
}

.progress-card-badge.expired {
  color: var(--color-text-light);
  background: rgba(255,255,255,0.08);
}

.progress-number-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: var(--space-base);
}

.progress-number-current {
  font-size: 80rpx;
  font-weight: 900;
  color: #e94560;
}

.progress-number-sep {
  font-size: 40rpx;
  color: var(--color-text-light);
  margin: 0 var(--space-xs);
}

.progress-number-target {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.progress-bar-bg {
  width: 100%;
  height: 16rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: var(--space-sm);
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.progress-tip {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  text-align: center;
  display: block;
}

/* ===== 已助力好友头像组 ===== */
.helpers-card {
  padding: var(--space-lg);
  margin-bottom: var(--space-base);
}

.section-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: var(--space-base);
}

.helpers-avatar-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.helper-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.helper-avatar-placeholder {
  background: #e94560;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.helper-avatar-empty {
  background: rgba(255,255,255,0.08);
  border: 2rpx dashed rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-light);
}

/* ===== 奖励卡片 ===== */
.reward-card {
  padding: var(--space-lg);
  margin-bottom: var(--space-base);
}

.reward-text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.reward-highlight {
  color: #e94560;
  font-weight: bold;
  font-size: var(--font-lg);
}

/* ===== 分享按钮 ===== */
.action-section {
  padding: 0 var(--space-base);
  margin-bottom: var(--space-base);
}

.btn-share {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #ffffff;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-share::after {
  border: none;
}

.btn-share-icon {
  font-size: 36rpx;
  margin-right: var(--space-xs);
}

.btn-share-text {
  font-size: var(--font-lg);
  font-weight: 600;
}

/* ===== 海报区 ===== */
.poster-section {
  padding: var(--space-lg);
  margin-bottom: var(--space-base);
}

.poster-tip {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  display: block;
  margin-bottom: var(--space-base);
}

.share-canvas {
  width: 100%;
  height: 400px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: #1a1a2e;
}

.btn-poster-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: rgba(233,69,96,0.1);
  color: #e94560;
  font-size: var(--font-base);
  font-weight: 600;
  border-radius: 44rpx;
  border: 2rpx solid rgba(233,69,96,0.3);
  margin-top: var(--space-base);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-poster-save-icon {
  font-size: 32rpx;
  margin-right: var(--space-xs);
}

.btn-poster-save-text {
  font-size: var(--font-base);
}

/* ===== 底部提示 ===== */
.footer-tip {
  text-align: center;
  padding: var(--space-lg) var(--space-base) 60rpx;
}

.footer-tip text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}
