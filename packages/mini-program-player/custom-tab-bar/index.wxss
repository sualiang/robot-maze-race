.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  transition: color 0.2s;
}

/* --- active --- */
.tab-item.active .tab-label {
  color: #e8453c;
  font-weight: 600;
}

/* ============ 首页图标 - 房子 ============ */
.icon-home {
  position: relative;
  width: 40rpx;
  height: 36rpx;
}
.home-roof {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-bottom: 16rpx solid #999;
  transition: border-bottom-color 0.2s;
}
.home-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 26rpx;
  height: 20rpx;
  border: 2.5rpx solid #999;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
  transition: border-color 0.2s;
}
.tab-item.active .home-roof { border-bottom-color: #e8453c; }
.tab-item.active .home-body { border-color: #e8453c; }

/* ============ 比赛图标 - 旗帜 ============ */
.icon-race {
  position: relative;
  width: 36rpx;
  height: 44rpx;
}
.race-pole {
  position: absolute;
  left: 4rpx;
  bottom: 0;
  width: 3rpx;
  height: 44rpx;
  background: #999;
  border-radius: 2rpx;
  transition: background 0.2s;
}
.race-flag {
  position: absolute;
  left: 7rpx;
  top: 4rpx;
  width: 26rpx;
  height: 18rpx;
  border: 2.5rpx solid #999;
  border-radius: 2rpx;
  background: rgba(153,153,153,0.06);
  transition: border-color 0.2s;
}
.tab-item.active .race-pole { background: #e8453c; }
.tab-item.active .race-flag { border-color: #e8453c; }

/* ============ 排行榜图标 - 柱状图 ============ */
.icon-chart {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 42rpx;
}
.chart-bar {
  width: 8rpx;
  border-radius: 3rpx;
  background: #999;
  transition: background 0.2s;
}
.bar1 { height: 20rpx; }
.bar2 { height: 30rpx; }
.bar3 { height: 42rpx; }
.tab-item.active .chart-bar { background: #e8453c; }

/* ============ 我的图标 - 人物 ============ */
.icon-profile {
  position: relative;
  width: 38rpx;
  height: 44rpx;
}
.profile-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 20rpx;
  border: 2.5rpx solid #999;
  border-radius: 50%;
  transition: border-color 0.2s;
}
.profile-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 34rpx;
  height: 20rpx;
  border: 2.5rpx solid #999;
  border-radius: 16rpx 16rpx 0 0;
  border-bottom: none;
  transition: border-color 0.2s;
}
.tab-item.active .profile-head { border-color: #e8453c; }
.tab-item.active .profile-body { border-color: #e8453c; }
