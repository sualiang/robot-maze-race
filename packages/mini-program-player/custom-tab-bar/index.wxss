.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #1a1a2e;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding-top: 8rpx;
  transition: all 0.2s;
}

.tab-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #888;
  font-weight: 600;
  transition: color 0.2s;
}

/* --- active --- */
.tab-item.active .tab-label {
  color: #e8453c;
  font-weight: 700;
}

/* ============ 首页图标 - 房子 ============ */
.icon-home {
  position: relative;
  width: 54rpx;
  height: 48rpx;
}
.home-roof {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 27rpx solid transparent;
  border-right: 27rpx solid transparent;
  border-bottom: 22rpx solid #888;
  transition: border-bottom-color 0.2s;
}
.home-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 26rpx;
  border: 3rpx solid #888;
  border-top: none;
  border-radius: 0 0 6rpx 6rpx;
  transition: border-color 0.2s;
}
.tab-item.active .home-roof { border-bottom-color: #e8453c; }
.tab-item.active .home-body { border-color: #e8453c; }

/* ============ 比赛图标 - 旗帜 ============ */
.icon-race {
  position: relative;
  width: 50rpx;
  height: 60rpx;
}
.race-pole {
  position: absolute;
  left: 6rpx;
  bottom: 0;
  width: 4rpx;
  height: 60rpx;
  background: #888;
  border-radius: 2rpx;
  transition: background 0.2s;
}
.race-flag {
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  width: 36rpx;
  height: 24rpx;
  border: 3rpx solid #888;
  border-radius: 3rpx;
  background: rgba(136,136,136,0.06);
  transition: border-color 0.2s;
}
.tab-item.active .race-pole { background: #e8453c; }
.tab-item.active .race-flag { border-color: #e8453c; }

/* ============ 排行榜图标 - 柱状图 ============ */
.icon-chart {
  display: flex;
  align-items: flex-end;
  gap: 7rpx;
  height: 58rpx;
}
.chart-bar {
  width: 11rpx;
  border-radius: 4rpx;
  background: #888;
  transition: background 0.2s;
}
.bar1 { height: 28rpx; }
.bar2 { height: 42rpx; }
.bar3 { height: 58rpx; }
.tab-item.active .chart-bar { background: #e8453c; }

/* ============ 我的图标 - 人物 ============ */
.icon-profile {
  position: relative;
  width: 52rpx;
  height: 60rpx;
}
.profile-head {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #888;
  border-radius: 50%;
  transition: border-color 0.2s;
}
.profile-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 26rpx;
  border: 3rpx solid #888;
  border-radius: 22rpx 22rpx 0 0;
  border-bottom: none;
  transition: border-color 0.2s;
}
.tab-item.active .profile-head { border-color: #e8453c; }
.tab-item.active .profile-body { border-color: #e8453c; }
