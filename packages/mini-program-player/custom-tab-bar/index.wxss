.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  background: #1a1a2e;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  height: 100%;
  padding-bottom: 8rpx;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.tab-text {
  font-size: 22rpx;
  color: #666680;
  font-weight: 500;
}

.tab-text-active {
  color: #e94560;
  font-weight: 700;
}