<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="text"
    class="tab-bar-item"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <text class="tab-icon">{{item.icon}}</text>
    <text class="tab-text {{selected === index ? 'tab-text-active' : ''}}">{{item.text}}</text>
  </view>
</view>