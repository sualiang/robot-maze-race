/* pages/register/register.wxss — 注册页 深色主题 */
page {
  background-color: #0f0f23;
}

.page {
  min-height: 100vh;
  padding-top: 60rpx;
  box-sizing: border-box;
}

/* ===== 头像区 ===== */
.avatar-area,
button.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 0 48rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  line-height: 1;
}

button.avatar-area::after {
  border: none;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #1e293b;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.avatar-hint {
  font-size: 24rpx;
  color: #475569;
  margin-top: 16rpx;
}

/* ===== 表单卡片 ===== */
.form-card {
  margin: 0 24rpx;
  background-color: #1a1a2e;
  border-radius: 12rpx;
  overflow: hidden;
}

.form-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  position: relative;
  box-sizing: border-box;
  font-size: 28rpx;
}

.form-cell::after {
  content: '';
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 0;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.06);
}

.form-cell:last-child::after {
  display: none;
}

.form-cell__hd {
  color: #e2e8f0;
  font-size: 28rpx;
  flex-shrink: 0;
  width: 140rpx;
}

.form-cell__bd {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 28rpx;
}

.form-cell__bd_right {
  text-align: right;
}

.form-input {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #e2e8f0;
  background: transparent;
  border: none;
  outline: none;
}

/* ===== 保存按钮 ===== */
.btn-area {
  padding: 80rpx 40rpx 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  background-color: #07C160;
  color: #fff;
}

.save-btn:active {
  background-color: #06ad56;
}

button.save-btn[disabled] {
  background-color: #0d6030;
  color: rgba(255, 255, 255, 0.5);
}
