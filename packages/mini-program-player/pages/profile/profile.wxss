/* 个人中心 V2.0 */

/* ===== 用户信息 ===== */
.profile-header {
  margin-bottom: var(--space-base);
}
.profile-user-row {
  display: flex;
  align-items: center;
}
.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-round);
  background: var(--color-bg-input);
  flex-shrink: 0;
}
.profile-user-text {
  margin-left: var(--space-base);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.profile-nickname-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.profile-nickname {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
}
.profile-gender {
  font-size: 30rpx;
  font-weight: 700;
}
.profile-gender.male { color: #64b5f6; }
.profile-gender.female { color: #f48fb1; }
.profile-phone {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* ===== 等级勋章 ===== */
.medal-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-base);
  margin-bottom: var(--space-base);
  border: 2rpx solid #ffd700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.15);
  border-radius: var(--radius-lg);
}
.medal-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
}
.medal-icon {
  font-size: 80rpx;
}
.medal-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #ffd700;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 0.3);
}

/* ===== 经验进度条 ===== */
.exp-section {
  margin-bottom: var(--space-base);
}
.exp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}
.exp-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
.exp-value {
  font-size: var(--font-sm);
  color: var(--color-text);
  font-weight: 600;
}
.progress-bar {
  height: 14rpx;
  background: var(--color-bg-input);
  border-radius: 7rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81, #ffd700);
  border-radius: 7rpx;
  transition: width 0.3s;
}
.exp-percent-text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  text-align: center;
  margin-top: var(--space-xs);
}

/* ===== 战斗力 + 排名 + 积分 ===== */
.combat-section {
  margin-bottom: var(--space-base);
}
.combat-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}
.combat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.combat-number {
  font-size: var(--font-huge);
  font-weight: 900;
  color: var(--color-primary);
  line-height: 1.1;
}
.combat-rank {
  font-size: var(--font-xxl);
}
.combat-points {
  font-size: var(--font-xxl);
  color: var(--color-warning);
}
.combat-label {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}
.combat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
}

/* ===== 三行核心数据 ===== */
.core-stats {
  margin-bottom: var(--space-base);
}
.core-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}
.core-stat-row + .core-stat-row {
  border-top: 1rpx solid var(--color-border);
}
.core-stat-label {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}
.core-stat-value {
  font-size: var(--font-lg);
  color: var(--color-text);
  font-weight: 700;
}

/* ===== 赛季未开启 ===== */
.season-closed {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-base);
  margin-bottom: var(--space-base);
}
.season-closed-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-base);
}
.season-closed-text {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-sm);
}
.season-closed-desc {
  font-size: var(--font-sm);
  color: var(--color-text-light);
}

/* ===== 菜单列表 ===== */
.menu-section {
  margin-bottom: var(--space-base);
  padding: 0;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-base);
}
.menu-icon {
  font-size: 36rpx;
  margin-right: var(--space-base);
}
.menu-label {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text);
}
.menu-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-light);
}
.menu-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 var(--space-base);
}

/* ===== 退出登录 ===== */
.logout-section {
  margin-top: var(--space-xl);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}
.logout-btn {
  color: var(--color-text-light);
  border: 1rpx solid var(--color-border);
}
