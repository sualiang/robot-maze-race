/* 我的页面 V2.0 - 完整重构 */
/* 设计基准 750rpx */
/* 页面背景: #0F172A, 卡片背景: #1E293B */

/* ===== 模块1: 用户信息栏 ===== */
.user-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: transparent;
}
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-bg-card, #1E293B);
  flex-shrink: 0;
}
.user-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.user-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
.user-phone {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ===== 模块2: 赛季段位卡片 ===== */
.medal-card {
  width: 686rpx;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx auto;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  position: relative;
}
.medal-card-hd {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.medal-upgrade-area {
  flex-shrink: 0;
  margin-left: auto;
  align-self: center;
}
.medal-icon-area {
  flex-shrink: 0;
}
.medal-icon-badge {
  font-size: 72rpx;
  display: block;
  line-height: 1;
}
.trophy-icon {
  width: 80rpx;
  height: 80rpx;
  display: block;
}
.medal-title-area {
  flex: 1;
}
.medal-level-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}
.medal-rank-text {
  font-size: 24rpx;
  color: #94A3B8;
  display: block;
  margin-top: 4rpx;
}

/* 进度条 */
.medal-progress-wrap {
  margin-top: 24rpx;
}
.medal-progress-bg {
  height: 12rpx;
  background: #334155;
  border-radius: 6rpx;
  overflow: hidden;
}
.medal-progress-fill {
  height: 100%;
  background: #F59E0B;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.medal-info-row {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.medal-exp-text {
  font-size: 24rpx;
  color: #94A3B8;
}
.medal-upgrade-desc {
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.4;
}

.medal-upgrade-btn {
  width: 140rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #FF3B5C;
  border-radius: 28rpx;
  color: #ffffff;
  font-size: 24rpx;
}
.medal-upgrade-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* 赛季未开启 */
.season-closed-card {
  width: 686rpx;
  margin: 24rpx auto;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
.season-closed-icon {
  font-size: 72rpx;
  width: 80rpx;
  height: 80rpx;
}
.season-closed-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
.season-closed-desc {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ===== 模块3: 福利资产卡片 ===== */
.assets-card {
  display: flex;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
.assets-card:active {
  opacity: 0.9;
}
.assets-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.assets-divider {
  width: 1rpx;
  background: #334155;
  margin: 0 24rpx;
}
.assets-number {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}
.assets-number-red {
  color: #FF3B5C;
}
.assets-number-gold {
  color: #F59E0B;
}
.assets-label {
  font-size: 28rpx;
  color: #E2E8F0;
}
.assets-subtext {
  font-size: 22rpx;
  color: #94A3B8;
}

/* ===== 模块4: 赛季数据轻览 ===== */
.stats-bar {
  display: flex;
  background: transparent;
  margin-bottom: 24rpx;
}
.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.stats-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
}
.stats-label {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ===== 模块5: 功能入口列表 ===== */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 32rpx;
  background: #1E293B;
  border-radius: 16rpx;
  gap: 16rpx;
}
.menu-item:active {
  opacity: 0.9;
}
.menu-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
}
.menu-right-text {
  font-size: 24rpx;
  color: #F59E0B;
  flex-shrink: 0;
}
.menu-arrow {
  font-size: 32rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

/* ===== 模块6: 退出登录按钮 ===== */
.logout-area {
  margin-top: 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
}
.logout-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 1rpx solid #334155;
  border-radius: 16rpx;
  color: #94A3B8;
  font-size: 28rpx;
}
.logout-btn:active {
  opacity: 0.7;
}
