<view class="page">

  <!-- ===== 1. 用户信息头部（点击进入编辑页） ===== -->
  <view class="profile-header card-elevated" bindtap="onEditProfile">
    <view class="profile-user-row">
      <image class="profile-avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="profile-user-text">
        <view class="profile-nickname-row">
          <text class="profile-nickname">{{userInfo.nickname || '未设置昵称'}}</text>
          <text wx:if="{{userInfo.gender === 'male'}}" class="profile-gender male">♂</text>
          <text wx:elif="{{userInfo.gender === 'female'}}" class="profile-gender female">♀</text>
        </view>
        <text class="profile-phone">{{userInfo.phone || ''}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 2. 赛季相关区域（接口返回 403 时隐藏） ===== -->
  <view wx:if="{{!seasonClosed}}">

    <!-- 等级勋章 -->
    <view class="medal-section card-elevated">
      <view class="medal-icon-wrapper">
        <text class="medal-icon">{{medal.icon || '🎖️'}}</text>
      </view>
      <text class="medal-name">{{medal.name || '青铜勋章'}}</text>
    </view>

    <!-- 经验进度条 -->
    <view class="exp-section card-elevated">
      <view class="exp-header">
        <text class="exp-label">经验值</text>
        <text class="exp-value">{{medal.currentExp || 0}} / {{medal.nextLevelExp || 100}}</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{expPercent}}%"></view>
      </view>
      <text class="exp-percent-text">已达成 {{expPercent}}%</text>
    </view>

    <!-- 战斗力 + 排名 -->
    <view class="combat-section card-elevated">
      <view class="combat-row">
        <view class="combat-item">
          <text class="combat-number">{{combatInfo.combatPower || '--'}}</text>
          <text class="combat-label">战斗力</text>
        </view>
        <view class="combat-divider"></view>
        <view class="combat-item">
          <text class="combat-number combat-rank">#{{combatInfo.rank || '--'}}</text>
          <text class="combat-label">排名</text>
        </view>
        <view class="combat-divider"></view>
        <view class="combat-item">
          <text class="combat-number combat-points">{{userInfo.points || 0}}</text>
          <text class="combat-label">积分</text>
        </view>
      </view>
    </view>

    <!-- 三行核心数据 -->
    <view class="core-stats card-elevated">
      <view class="core-stat-row">
        <text class="core-stat-label">完赛场次</text>
        <text class="core-stat-value">{{coreStats.totalRaces || 0}}</text>
      </view>
      <view class="core-stat-row">
        <text class="core-stat-label">最佳排名</text>
        <text class="core-stat-value">{{coreStats.bestRank || '-'}}</text>
      </view>
      <view class="core-stat-row">
        <text class="core-stat-label">毅力加成</text>
        <text class="core-stat-value">+{{coreStats.perseveranceBonus || 0}}%</text>
      </view>
    </view>

  </view>

  <!-- ===== 赛季未开启 ===== -->
  <view wx:elif="{{seasonClosed}}" class="season-closed card-elevated">
    <text class="season-closed-icon">🏆</text>
    <text class="season-closed-text">赛季即将开启</text>
    <text class="season-closed-desc">敬请期待</text>
  </view>

  <!-- ===== 3. 功能菜单列表 ===== -->
  <view class="menu-section card-elevated">
    <view class="menu-item" data-url="/pages/coupon/coupon" bindtap="onNavigate">
      <text class="menu-icon">🎫</text>
      <text class="menu-label">我的卡包</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" data-url="/pages/lottery/lottery" bindtap="onNavigate">
      <text class="menu-icon">🎰</text>
      <text class="menu-label">积分抽奖</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" data-url="/pages/task/task" bindtap="onNavigate">
      <text class="menu-icon">📋</text>
      <text class="menu-label">任务中心</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" data-url="/pages/evaluation/evaluation" bindtap="onNavigate">
      <text class="menu-icon">📊</text>
      <text class="menu-label">评估区</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" data-url="/pages/checkin/checkin" bindtap="onNavigate">
      <text class="menu-icon">📅</text>
      <text class="menu-label">签到打卡</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" data-url="/pages/help/help" bindtap="onNavigate">
      <text class="menu-icon">🤝</text>
      <text class="menu-label">好友助力</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- ===== 4. 退出登录 ===== -->
  <view class="logout-section">
    <view class="btn btn-ghost logout-btn" bindtap="onLogout">
      退出登录
    </view>
  </view>

</view>
