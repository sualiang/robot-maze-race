<!-- 个人中心 -- 未登录显示 CTA，已登录显示完整信息 -->
<view class="page">

  <!-- ===== 未登录状态 ===== -->
  <view wx:if="{{!isLoggedIn}}" class="unlogged-section">
    <image class="unlogged-avatar" src="/assets/images/default-avatar.png" mode="aspectFill" />
    <text class="unlogged-title">未登录</text>
    <text class="unlogged-desc">登录后可查看个人信息和赛季数据</text>
    <button class="unlogged-btn" bindtap="onGoLogin">
      <image class="unlogged-btn-icon" src="/assets/images/wechat-icon.svg" mode="aspectFit" />
      <text>微信登录</text>
    </button>
  </view>

  <block wx:else>

  <!-- 模块1: 用户信息栏 -->
  <view class="user-card" bindtap="onEditProfile">
    <image class="user-avatar" src="{{userInfo.avatar_url || userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="user-nickname">{{userInfo.nickname || '未设置昵称'}}</text>
      <text class="user-phone">{{userInfo.phone || ''}}</text>
    </view>
  </view>

  <!-- 模块2: 赛季段位卡片 -->
  <view wx:if="{{!seasonClosed}}" class="medal-card">
    <view class="medal-card-hd">
      <view class="medal-icon-area">
        <image class="medal-icon-badge trophy-icon" src="/assets/images/trophy-{{medalInfo.level}}.svg" mode="aspectFit" />
      </view>
      <view class="medal-title-area">
        <text class="medal-level-name">{{medalInfo.levelName}}</text>
        <text class="medal-rank-text">商圈排名 第{{medalInfo.rank}}名</text>
      </view>
      <view class="medal-upgrade-area">
        <view class="medal-upgrade-btn" bindtap="onUpgrade">去升级</view>
      </view>
    </view>
    <view class="medal-progress-wrap">
      <view class="medal-progress-bg">
        <view class="medal-progress-fill" style="width: {{medalInfo.expPercent}}%"></view>
      </view>
    </view>
    <view class="medal-info-row">
      <text class="medal-exp-text">{{medalInfo.currentExp}} / {{medalInfo.nextLevelExp}} 成长值</text>
      <text class="medal-upgrade-desc">{{medalInfo.upgradeDesc}}</text>
    </view>
  </view>

  <view wx:elif="{{seasonClosed}}" class="season-closed-card">
    <image class="season-closed-icon" src="/assets/images/trophy-1.svg" mode="aspectFit" />
    <text class="season-closed-text">赛季即将开启</text>
    <text class="season-closed-desc">敬请期待</text>
  </view>

  <!-- 模块3: 福利资产卡片 -->
  <view class="assets-card">
    <view class="assets-col" bindtap="onDeductTap">
      <text class="assets-number assets-number-red">¥{{assets.deductible}}</text>
      <text class="assets-label">参赛抵扣卡</text>
      <text class="assets-subtext">买参赛包直接抵扣</text>
    </view>
    <view class="assets-divider"></view>
    <view class="assets-col" bindtap="onCouponTap">
      <text class="assets-number assets-number-gold">¥{{assets.couponTotal}}</text>
      <text class="assets-label">消费券</text>
      <text class="assets-subtext">满减/兑换通用</text>
    </view>
  </view>

  <!-- 模块4: 赛季数据轻览 -->
  <view class="stats-bar">
    <view class="stats-item">
      <text class="stats-value">{{seasonStats.totalRaces}}场</text>
      <text class="stats-label">完赛场次</text>
    </view>
    <view class="stats-item">
      <text class="stats-value">{{seasonStats.bestTime}}</text>
      <text class="stats-label">最佳成绩</text>
    </view>
  </view>

  <!-- 模块5: 功能入口列表 -->
  <view class="menu-section">
    <view
      wx:for="{{menuList}}"
      wx:key="key"
      class="menu-item"
      data-key="{{item.key}}"
      data-url="{{item.url}}"
      bindtap="onMenuItemTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-label">{{item.label}}</text>
      <text wx:if="{{item.rightText}}" class="menu-right-text">{{item.rightText}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 模块6: 退出登录按钮 -->
  <view class="logout-area">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>

  </block>

</view>
