/* pages/help/help.wxss */
/* 好友助力裂变页样式 */

/* ===== 加载/错误状态 ===== */
.loading-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.loading-text {
  font-size: var(--font-size-base);
  color: var(--color-text-light);
}

.error-emoji {
  font-size: 80rpx;
  margin-bottom: var(--spacing-base);
}

.error-title {
  font-size: var(--font-size-lg);
  color: var(--color-text);
  font-weight: bold;
  margin-bottom: var(--spacing-xs);
}

.error-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-bottom: var(--spacing-base);
}

.retry-btn {
  width: 300rpx;
}

/* ===== Hero 头部 ===== */
.help-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
  background: linear-gradient(135deg, #533483, #e94560);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-base);
}

.hero-icon {
  font-size: 64rpx;
  margin-bottom: var(--spacing-sm);
}

.hero-title {
  font-size: var(--font-size-xl);
  font-weight: 900;
  color: #fff;
  margin-bottom: var(--spacing-xs);
}

.hero-sub {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.75);
}

/* ===== 目标卡片 ===== */
.target-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-base);
}

.target-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.target-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

.target-badge {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: rgba(233,69,96,0.1);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.target-pkg {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text);
  display: block;
  margin-bottom: var(--spacing-lg);
}

/* 进度条 */
.progress-section {
  margin-bottom: var(--spacing-sm);
}

.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: var(--color-bg-secondary);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text-row {
  display: flex;
  justify-content: space-between;
}

.progress-current {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: bold;
}

.progress-target {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* ===== 助力者列表 ===== */
.helpers-section {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-base);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: var(--spacing-base);
}

.helpers-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-base);
}

.helper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.helper-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: var(--spacing-xs);
  background: var(--color-bg-secondary);
}

.helper-name {
  font-size: var(--font-size-xs);
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.helper-time {
  font-size: 18rpx;
  color: var(--color-text-light);
}

/* ===== 分享卡片区 ===== */
.share-card-section {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-base);
}

.share-tip {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  display: block;
  margin-bottom: var(--spacing-base);
}

.share-canvas {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-bg-secondary);
}

.share-btns {
  display: flex;
  gap: var(--spacing-base);
  margin-top: var(--spacing-lg);
}

.share-action-btn {
  flex: 1;
  height: 80rpx;
  font-size: var(--font-size-base);
  border-radius: var(--radius-base);
}

.share-action-btn::after {
  border: none;
}

/* ===== 助力按钮 ===== */
.action-section {
  margin-bottom: var(--spacing-lg);
}

.help-action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border: 2rpx dashed rgba(233,69,96,0.3);
}

.help-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
}

.help-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: var(--spacing-lg);
  padding: 0 var(--spacing-base);
}

.help-btn {
  width: 500rpx;
  height: 88rpx;
  font-size: var(--font-size-lg);
}

/* ===== 已完成/已助力/已过期 ===== */
.help-done-card, .help-expired-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.done-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-base);
}

.done-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--spacing-xs);
}

.done-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
}

/* ===== 有效期 ===== */
.expiry-tip {
  text-align: center;
  padding: var(--spacing-lg);
}

.expiry-tip text {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}
