/* pages/help/assist/assist.wxss - 好友的助力落地页 */

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(233,69,96,0.2);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-base);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-base);
  color: var(--color-text-light);
}

/* ===== 登录提示 ===== */
.login-state, .error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
  padding: var(--space-xl);
}

.login-emoji, .error-emoji {
  font-size: 80rpx;
  margin-bottom: var(--space-base);
}

.login-title, .error-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.login-desc, .error-desc {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  margin-bottom: var(--space-lg);
  text-align: center;
}

.btn {
  text-align: center;
  font-size: var(--font-base);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-login {
  width: 400rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #e94560, #ff6b81);
}

.btn-login-text, .btn-retry-text {
  color: #ffffff;
  font-size: var(--font-lg);
  font-weight: 600;
}

.btn-retry {
  width: 400rpx;
  height: 88rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.15);
}

/* ===== 邀请卡片 ===== */
.invite-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl);
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-base);
}

.invite-icon-row {
  margin-bottom: var(--space-base);
}

.invite-icon {
  font-size: 72rpx;
}

.invite-title {
  font-size: var(--font-base);
  color: var(--color-text);
  text-align: center;
  line-height: 1.6;
  margin-bottom: var(--space-lg);
  padding: 0 var(--space-base);
}

.inviter-name {
  color: #e94560;
  font-weight: bold;
}

.invite-progress-row {
  width: 100%;
  display: flex;
  align-items: center;
  gap: var(--space-base);
}

.invite-progress-bar-bg {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 6rpx;
  overflow: hidden;
}

.invite-progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.invite-progress-text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  font-weight: 600;
  white-space: nowrap;
}

/* ===== 预览已助力头像 ===== */
.preview-card {
  padding: var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  margin-bottom: var(--space-base);
}

.preview-title {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  display: block;
  margin-bottom: var(--space-sm);
}

.preview-avatar-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.preview-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.preview-avatar-placeholder {
  background: #e94560;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-placeholder-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ===== 助力按钮 ===== */
.btn-assist {
  width: calc(100% - 2 * var(--space-base));
  height: 100rpx;
  margin: 0 var(--space-base) var(--space-base);
  background: linear-gradient(135deg, #e94560, #ff6b81);
  font-size: var(--font-lg);
  font-weight: 700;
  color: #ffffff;
  border-radius: 50rpx;
  gap: var(--space-xs);
}

.btn-assist-icon {
  font-size: 40rpx;
}

.btn-assist-text {
  font-size: var(--font-lg);
  font-weight: 700;
}

/* ===== 我也要发起按钮 ===== */
.btn-own {
  width: calc(100% - 2 * var(--space-base));
  height: 80rpx;
  margin: 0 var(--space-base);
  background: rgba(233,69,96,0.08);
  border: 2rpx solid rgba(233,69,96,0.3);
  border-radius: 40rpx;
  color: #e94560;
  font-size: var(--font-base);
  font-weight: 500;
}

.btn-own-text {
  font-size: var(--font-base);
  font-weight: 500;
}

/* ===== 底部提示 ===== */
.assist-footer-tip {
  text-align: center;
  padding: var(--space-lg) var(--space-base) 60rpx;
}

.assist-footer-tip text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

/* ===== 已助力完成/已过期 ===== */
.assist-done-card, .assist-expired-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin: 0 var(--space-base) var(--space-base);
}

.assist-done-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-base);
}

.assist-done-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.assist-done-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  text-align: center;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 560rpx;
  background: #1a1a2e;
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-base);
}

.modal-title {
  font-size: var(--font-xl);
  font-weight: bold;
  color: #ffffff;
  margin-bottom: var(--space-xs);
}

.modal-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: var(--space-lg);
}

.modal-btn-row {
  width: 100%;
  display: flex;
  gap: var(--space-base);
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: var(--font-base);
  font-weight: 600;
  border-radius: 40rpx;
}

.modal-btn-primary {
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #ffffff;
}

.modal-btn-secondary {
  background: rgba(255,255,255,0.08);
  color: var(--color-text);
  border: 2rpx solid rgba(255,255,255,0.15);
}

.modal-close {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: var(--space-lg);
  padding: var(--space-xs) var(--space-base);
}
