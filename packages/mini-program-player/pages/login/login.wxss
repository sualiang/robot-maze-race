/* ===== 登录页 - 深色主题 ===== */

.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景光晕 */
.login-container::before {
  content: '';
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(7, 193, 96, 0.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.login-container::after {
  content: '';
  position: absolute;
  bottom: -300rpx;
  left: -200rpx;
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(83, 52, 131, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* ===== 登录卡片容器 ===== */
.login-box {
  width: 100%;
  max-width: 580rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* ===== Logo 区域 ===== */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-xl);
}

.logo-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-base);
  box-shadow: 0 0 30rpx rgba(7, 193, 96, 0.2);
}

.app-name {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: var(--space-xs);
}

/* ===== 表单区域 ===== */
.form-area {
  width: 100%;
}

/* ===== 微信登录按钮 ===== */
.wx-login-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07C160;
  color: #fff;
  border-radius: 48rpx;
  font-size: var(--font-xl);
  font-weight: 600;
  letter-spacing: 4rpx;
  border: none;
  margin-top: var(--space-lg);
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.35);
  transition: opacity 0.2s, transform 0.15s;
}

.wx-login-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.wx-login-btn[disabled] {
  background: rgba(7, 193, 96, 0.5);
  box-shadow: none;
  transform: none;
  opacity: 1;
}

.wx-login-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* ===== 注册链接 ===== */
.register-area {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: var(--space-xl);
  padding-bottom: 20rpx;
}

.register-text {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.register-link {
  font-size: var(--font-base);
  color: #07C160;
  margin-left: 6rpx;
  font-weight: 500;
  padding: 4rpx 8rpx;
}

/* ===== 辅助类 ===== */
.hidden {
  display: none;
}
