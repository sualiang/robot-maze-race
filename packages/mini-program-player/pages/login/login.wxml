<!-- pages/login/login.wxml — 手动登录（手机号 + 微信 code） -->
<view class="page">
  <!-- Logo + 标题 -->
  <view class="header">
    <image class="logo" src="/assets/images/logo-avatar.png" mode="aspectFit" />
    <text class="title">迷宫竞速</text>
    <text class="subtitle">输入手机号，开启竞速之旅</text>
  </view>

  <!-- 手机号输入 -->
  <view class="form-card">
    <view class="form-cell">
      <text class="form-cell__hd">手机号</text>
      <view class="form-cell__bd form-cell__bd_right">
        <input
          class="form-input"
          type="number"
          maxlength="11"
          value="{{phone}}"
          placeholder="请输入手机号"
          placeholder-style="color:#475569"
          bindinput="onPhoneInput"
        />
      </view>
    </view>
  </view>

  <!-- 登录按钮 -->
  <view class="login-area">
    <button
      class="weui-btn weui-btn_primary"
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="onLogin"
    >
      <text>{{loading ? '登录中...' : '登录'}}</text>
    </button>
  </view>
</view>
