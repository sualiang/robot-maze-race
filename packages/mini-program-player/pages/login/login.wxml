<!-- pages/login/login.wxml — 手机号快捷登录 -->
<view class="page">
  <!-- Logo + 标题 -->
  <view class="header">
    <image class="logo" src="/assets/images/logo-avatar.png" mode="aspectFit" />
    <text class="title">迷宫竞速</text>
    <text class="subtitle">手机号快捷登录，开启竞速之旅</text>
  </view>

  <!-- 手机号快捷登录按钮 -->
  <view class="login-area">
    <button
      class="login-btn"
      loading="{{loading}}"
      disabled="{{loading}}"
      bindtap="onLogin"
    >
      <text class="login-btn-icon">📱</text>
      <text>{{loading ? '登录中...' : '手机号快捷登录'}}</text>
    </button>

    <!-- 取消/返回 -->
    <view class="login-cancel" bindtap="onCancel">
      <text>暂不登录，先看看</text>
    </view>
  </view>
</view>