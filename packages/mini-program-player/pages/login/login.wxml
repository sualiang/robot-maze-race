<view class="login-container">
  <view class="login-box">
    <!-- Logo + 应用名 -->
    <view class="logo-area">
      <image class="logo-image" src="/assets/images/logo-avatar.png" mode="aspectFit" />
      <text class="app-name">迷宫竞速</text>
      <text class="app-subtitle">微信一键登录</text>
    </view>

    <!-- 微信登录按钮 -->
    <view class="form-area">
      <button
        class="wx-login-btn"
        loading="{{loading}}"
        disabled="{{loading}}"
        bindtap="doWxLogin"
      >
        <text class="wx-login-icon">🔐</text>
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </button>

      <!-- 注册链接 -->
      <view class="register-area">
        <text class="register-text">新用户？</text>
        <text class="register-link" bindtap="doRegister">完善资料</text>
      </view>
    </view>
  </view>
</view>
