/* 编辑资料页 — WeUI 白底风格 */
page {
  background-color: #f6f6f6;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
}

/* WeUI 风格 cell */
.weui-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  background-color: #fff;
  position: relative;
  border: none;
  border-radius: 0;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: inherit;
  text-align: left;
}

.weui-cell::after {
  content: '';
  position: absolute;
  left: 30rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background-color: #e5e5e5;
}

.weui-cell:last-child::after {
  left: 0;
}

.weui-cell_access {
  justify-content: space-between;
}

.weui-cell__hd {
  color: #000;
  font-size: 28rpx;
  flex-shrink: 0;
  width: 140rpx;
}

.weui-cell__bd {
  flex: 1;
  color: #000;
  font-size: 28rpx;
}

.weui-cell__bd_right {
  text-align: right;
}

.weui-cell__bd_readonly {
  color: #999;
}

.weui-cell__ft {
  flex-shrink: 0;
}

.weui-cell__ft_arrow::after {
  content: '';
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid #c7c7cc;
  border-bottom: 3rpx solid #c7c7cc;
  transform: rotate(-45deg);
}

/* 头像预览 */
.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background-color: #e5e5e5;
}

/* 昵称输入 */
.weui-input {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #000;
  background: transparent;
  border: none;
  outline: none;
}

.weui-input::placeholder {
  color: #b2b2b2;
}

/* 保存按钮区 */
.btn-area {
  padding: 40rpx 30rpx;
}

.weui-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.weui-btn_primary {
  background-color: #07C160;
  color: #fff;
}

.weui-btn_primary:active {
  background-color: #06ad56;
}

/* 原生按钮去样式 */
button.weui-cell {
  padding: 28rpx 30rpx;
  margin: 0;
}

button.weui-cell::after {
  border: none;
}
