/* 编辑资料页 — App深色主题 */
page {
  background-color: #0f0f23;
}

.page {
  min-height: 100vh;
  padding-top: 24rpx;
  box-sizing: border-box;
}

/* 表单行 */
.form-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  background-color: #1a1a2e;
  position: relative;
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
}

.form-cell::after {
  content: '';
  position: absolute;
  left: 30rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.08);
}

.form-cell:last-child::after {
  left: 0;
}

.form-cell_tap:active {
  background-color: #22223a;
}

.form-cell__hd {
  color: #e2e8f0;
  font-size: 28rpx;
  flex-shrink: 0;
  width: 140rpx;
}

.form-cell__bd {
  flex: 1;
  color: #e2e8f0;
  font-size: 28rpx;
}

.form-cell__bd_right {
  text-align: right;
}

.form-cell__bd_readonly .form-cell__value {
  color: #64748b;
}

.form-cell__arrow {
  flex-shrink: 0;
  color: #475569;
  font-size: 36rpx;
  margin-left: 8rpx;
}

.form-cell__value {
  color: #e2e8f0;
}

/* 头像预览 */
.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background-color: #1e293b;
}

/* 昵称输入 */
.form-input {
  width: 100%;
  text-align: right;
  font-size: 28rpx;
  color: #e2e8f0;
  background: transparent;
  border: none;
  outline: none;
}

/* 保存按钮区 */
.btn-area {
  padding: 48rpx 30rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  background-color: #07C160;
  color: #fff;
}

.save-btn:active {
  background-color: #06ad56;
}
