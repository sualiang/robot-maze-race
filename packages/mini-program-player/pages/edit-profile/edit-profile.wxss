.page {
  padding: 20rpx;
}

.section {
  background: #1a1a2e;
  border-radius: 14rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  min-height: 56rpx;
}

.field-row + .field-row {
  border-top: 1rpx solid rgba(255,255,255,0.04);
}

.field-label {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
  width: 140rpx;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #e0e0e0;
  text-align: right;
  background: transparent;
  border: none;
  outline: none;
}

.field-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.field-value {
  font-size: 28rpx;
  color: #e0e0e0;
}

.field-placeholder {
  color: #666;
}

.arrow-icon {
  font-size: 32rpx;
  color: #666;
}

.avatar-preview {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.1);
}

/* ===== 原生按钮去样式 ===== */
.native-btn {
  width: 100%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
  font-size: inherit;
  text-align: left;
  border-radius: 0;
}

.native-btn::after {
  border: none;
}

/* ===== 保存按钮 ===== */
.save-section {
  margin-top: 60rpx;
  padding: 0 20rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 44rpx;
}
