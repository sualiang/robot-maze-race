<view class="page">

  <!-- 头像 - 微信原生 chooseAvatar -->
  <view class="section">
    <button class="native-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="field-row">
        <text class="field-label">头像</text>
        <view class="field-value-row">
          <image class="avatar-preview" src="{{avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </button>
  </view>

  <!-- 昵称 - 微信原生昵称输入 -->
  <view class="section">
    <view class="field-row">
      <text class="field-label">昵称</text>
      <input class="field-input" type="nickname" value="{{nickname}}" placeholder="请输入昵称" maxlength="12" bindinput="onNicknameInput" />
    </view>
  </view>

  <!-- 性别 -->
  <view class="section">
    <picker mode="selector" range="{{genderOptions}}" bindchange="onGenderChange">
      <view class="field-row">
        <text class="field-label">性别</text>
        <view class="field-value-row">
          <text class="field-value">{{genderOptions[genderIndex]}}</text>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </picker>
  </view>

  <!-- 手机号 - 微信原生 getPhoneNumber -->
  <view class="section">
    <button class="native-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <view class="field-row">
        <text class="field-label">手机号</text>
        <view class="field-value-row">
          <text class="field-value {{phone ? '' : 'field-placeholder'}}">{{phone || '点击获取'}}</text>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </button>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <view class="btn btn-primary save-btn" bindtap="onSave">保存</view>
  </view>

</view>
