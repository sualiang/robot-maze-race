<!-- pages/edit-profile/edit-profile.wxml — 完善个人信息（WeUI 白底风格） -->
<view class="page">
  <!-- 头像 — 微信原生 chooseAvatar -->
  <button class="weui-cell weui-cell_access" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
    <view class="weui-cell__hd">头像</view>
    <view class="weui-cell__bd weui-cell__bd_right">
      <image class="avatar-preview" src="{{avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="weui-cell__ft weui-cell__ft_arrow"></view>
  </button>

  <!-- 昵称 — 微信原生 type="nickname" -->
  <view class="weui-cell">
    <view class="weui-cell__hd">昵称</view>
    <view class="weui-cell__bd weui-cell__bd_right">
      <input class="weui-input" type="nickname" value="{{nickname}}" placeholder="请输入昵称" maxlength="12" bindinput="onNicknameInput" />
    </view>
  </view>

  <!-- 性别 — picker -->
  <picker mode="selector" range="{{genderOptions}}" bindchange="onGenderChange">
    <view class="weui-cell weui-cell_access">
      <view class="weui-cell__hd">性别</view>
      <view class="weui-cell__bd weui-cell__bd_right">
        {{genderOptions[genderIndex]}}
      </view>
      <view class="weui-cell__ft weui-cell__ft_arrow"></view>
    </view>
  </picker>

  <!-- 手机号 — 只读 -->
  <view class="weui-cell">
    <view class="weui-cell__hd">手机号</view>
    <view class="weui-cell__bd weui-cell__bd_right weui-cell__bd_readonly">
      {{phone || '未获取'}}
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="weui-btn weui-btn_primary" bindtap="onSave">保存</button>
  </view>
</view>
