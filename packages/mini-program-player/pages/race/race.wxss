/**
 * pages/race/race.wxss - 比赛页 V2 重做
 * 设计基准: 750rpx
 * 配色: #0F172A 背景 | #1E293B 卡片 | #FF3B5C 主色 | #F59E0B 金色
 *       #E2E8F0 一级正文 | #94A3B8 二级辅助 | #334155 分割线
 */

/* ===== 页面容器 ===== */
.race-page {
  min-height: 100vh;
  background: #0F172A;
  padding: 0 32rpx 140rpx; /* 底部留足安全区域 + footer bar */
}

/* ===== 加载遮罩 ===== */
.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

/* ===== 模块1: 顶部标题 ===== */
.race-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 0;
}

.race-header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #E2E8F0;
}

/* ===== 模块2 — 状态A: 无记录空态 ===== */
.action-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 40rpx;
}

.action-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #E2E8F0;
  text-align: center;
  margin-bottom: 12rpx;
}

.action-empty-desc {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  margin-bottom: 32rpx;
}

.action-empty-illustration {
  width: 160rpx;
  height: 160rpx;
  font-size: 100rpx;
  line-height: 160rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 去扫码参赛按钮 */
.btn-scan {
  width: 320rpx;
  height: 88rpx;
  background: #FF3B5C;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-scan text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.btn-scan:active {
  opacity: 0.9;
  transform: scale(0.95);
}

/* ===== 模块2 — 状态B: 最佳成绩卡片 ===== */
.best-card {
  width: 686rpx;
  margin: 0 auto;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.best-card:active {
  opacity: 0.9;
  transform: scale(0.97);
}

.best-card-label {
  font-size: 28rpx;
  font-weight: 400;
  color: #94A3B8;
  margin-bottom: 16rpx;
}

.best-card-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #F59E0B;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.best-card-desc {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
  margin-bottom: 24rpx;
}

.best-card-tip {
  font-size: 24rpx;
  color: #FF3B5C;
  text-align: center;
}

/* ===== 模块3: 历史参赛记录 ===== */
.history-section {
  margin-top: 16rpx; /* 与上方模块自然分隔 */
}

.history-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #E2E8F0;
  padding: 24rpx 0;
}

/* 加载骨架 */
.history-loading {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-skeleton-item {
  height: 120rpx;
  background: #1E293B;
  border-radius: 16rpx;
  opacity: 0.5;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.8; }
}

/* 单条记录 */
.history-item {
  height: 120rpx;
  background: #1E293B;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  /* 三栏布局: 左侧成绩日期 | 中间排名奖牌 | 右侧成长积分 */
}

.history-item:active {
  background: #243044;
}

/* 左侧: 成绩 + 日期 */
.history-left {
  display: flex;
  flex-direction: column;
  min-width: 140rpx;
  flex-shrink: 0;
}

.history-score {
  font-size: 36rpx;
  font-weight: 600;
  color: #E2E8F0;
  line-height: 1.3;
}

.history-date {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.3;
  margin-top: 4rpx;
}

/* 中间: 排名 + 奖牌 */
.history-middle {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.history-medal {
  font-size: 32rpx;
  line-height: 1.2;
}

.history-rank {
  font-size: 30rpx;
  font-weight: 500;
  color: #E2E8F0;
  line-height: 1.3;
}

/* 右侧: 成长 + 积分 */
.history-right {
  flex-shrink: 0;
  margin-left: auto;
  display: flex;
  align-items: center;
}

.history-bonus {
  font-size: 24rpx;
  color: #F59E0B;
  text-align: right;
  line-height: 1.3;
}

/* 无记录占位 */
.history-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
}

.history-empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* ===== 模块4: 底部固定转化条 ===== */
.race-footer-bar {
  position: fixed;
  bottom: 100rpx; /* 假设Tab栏约100rpx */
  left: 0;
  right: 0;
  height: 80rpx;
  background: rgba(30, 41, 59, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  /* 配合安全区域 */
  padding-bottom: env(safe-area-inset-bottom, 0);
}

.race-footer-bar:active {
  opacity: 0.85;
}

.footer-bar-text {
  font-size: 28rpx;
  color: #94A3B8;
  text-align: center;
}

.footer-bar-highlight {
  color: #FF3B5C;
}
