/* pages/race/race.wxss - 比赛页样式 */
/* 背景 #0F172A | 卡片 #1E293B | 强调色 #FF3B5C | 文字 #E2E8F0 */

.race-page {
  min-height: 100vh;
  background: #0F172A;
  padding-bottom: 160rpx;
}

/* 加载态 */
.loading-mask {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #334155;
  border-top-color: #FF3B5C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 顶部标题 */
.race-header {
  padding: 40rpx 32rpx 20rpx;
}

.race-header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #E2E8F0;
}

/* 赛场名徽章 */
.venue-badge {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 59, 92, 0.1);
  border: 1rpx solid rgba(255, 59, 92, 0.2);
  border-radius: 16rpx;
}

.venue-badge-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.venue-badge-name {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 状态1: 无上下文空态 */
.action-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 40rpx;
}

.action-empty-illustration {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.action-empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #E2E8F0;
  margin-bottom: 16rpx;
  text-align: center;
}

.action-empty-desc {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 48rpx;
  text-align: center;
}

.btn-scan {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 480rpx;
  height: 88rpx;
  background: #FF3B5C;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 最佳成绩卡片 */
.best-card {
  margin: 0 32rpx 32rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #1E293B 0%, #1A2538 100%);
  border: 1rpx solid #334155;
  border-radius: 24rpx;
}

.best-card-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
  display: block;
}

.best-card-score {
  font-size: 64rpx;
  font-weight: 800;
  color: #FF3B5C;
  margin-bottom: 16rpx;
  display: block;
}

.best-card-desc {
  font-size: 26rpx;
  color: #CBD5E1;
  margin-bottom: 8rpx;
  display: block;
}

.best-card-tip {
  font-size: 22rpx;
  color: #64748B;
  display: block;
}

/* 参赛行动按钮区 */
.race-cta-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 32rpx 40rpx;
}

.race-cta-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: #FF3B5C;
  border-radius: 48rpx;
  margin-bottom: 16rpx;
}

.race-cta-btn.race-cta-buy {
  background: linear-gradient(135deg, #6366F1, #8B5CF6);
}

.race-cta-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.race-cta-hint {
  font-size: 24rpx;
  color: #64748B;
}

.race-cta-hint-empty {
  color: #EF4444;
}

/* 历史记录区 */
.history-section {
  padding: 0 32rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #E2E8F0;
  margin-bottom: 24rpx;
  display: block;
}

.history-loading {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-skeleton-item {
  height: 80rpx;
  background: #1E293B;
  border-radius: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #1E293B;
}

.history-left {
  flex: 1;
}

.history-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #E2E8F0;
  display: block;
}

.history-date {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
  display: block;
}

.history-middle {
  display: flex;
  align-items: center;
  margin: 0 24rpx;
}

.history-medal {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.history-rank {
  font-size: 26rpx;
  color: #94A3B8;
}

.history-right {
  flex-shrink: 0;
}

.history-bonus {
  font-size: 22rpx;
  color: #F59E0B;
}

.history-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.history-empty-text {
  font-size: 26rpx;
  color: #64748B;
}

/* 底部固定条 */
.race-footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: #1E293B;
  border-top: 1rpx solid #334155;
}

.footer-bar-text {
  font-size: 26rpx;
  color: #94A3B8;
}

.footer-bar-highlight {
  color: #FF3B5C;
  font-weight: 600;
}
