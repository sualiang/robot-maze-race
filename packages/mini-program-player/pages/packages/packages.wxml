<!-- pages/packages/packages.wxml -->
<!-- 参赛包购买页：展示剩余次数、参赛包列表、购买流程 -->

<view class="page">

  <!-- ===== 顶部提示条 ===== -->
  <view wx:if="{{!loading}}" class="top-banner">
    <text class="banner-icon">📢</text>
    <text class="banner-text">当前剩余 <text class="banner-count">{{remainCount}}</text> 次，需要补充参赛次数</text>
  </view>

  <!-- ===== 参赛包列表 ===== -->
  <view wx:if="{{!loading && !empty}}" class="package-list">
    <view
      wx:for="{{packageList}}"
      wx:key="id"
      class="package-card card"
    >
      <!-- 标签 -->
      <view wx:if="{{item.tag}}" class="pkg-tag tag-{{item.tagType || 'hot'}}">{{item.tag}}</view>

      <!-- 卡片主内容 -->
      <view class="pkg-body">
        <view class="pkg-name-area">
          <text class="pkg-name">{{item.name}}</text>
          <text wx:if="{{item.description}}" class="pkg-desc">{{item.description}}</text>
        </view>

        <!-- 次数展示 -->
        <view class="pkg-count-area">
          <text class="pkg-count-number">{{item.raceCount}}</text>
          <text class="pkg-count-unit">次参赛</text>
        </view>

        <!-- 有效期（去掉日历图标） -->
        <view class="pkg-meta">
          <text class="pkg-meta-text">有效期 {{item.validDays}} 天</text>
        </view>
      </view>

      <!-- 礼券组合展示 -->
      <view wx:if="{{item.coupons && item.coupons.length > 0}}" class="pkg-reward-area">
        <text class="reward-title">🎁 购包即赠礼券</text>
        <view class="reward-coupon-item" wx:for="{{item.coupons}}" wx:for-item="coupon" wx:key="couponId">
          <view class="reward-coupon-name">
            <text>{{coupon.couponName}}</text>
            <text class="reward-coupon-merchant">{{coupon.merchantName}}</text>
          </view>
          <text class="reward-coupon-value">¥{{coupon.couponValueText}}</text>
        </view>
        <text class="reward-title" style="margin-top:6rpx;text-align:right;">
          总价值 <text class="reward-total">¥{{item.totalRewardValueText}}</text>
        </text>
      </view>

      <!-- 价格 & 购买 -->
      <view class="pkg-footer">
        <view class="pkg-price-area">
          <text class="price-symbol">¥</text>
          <text class="price-number">{{item.salePriceText}}</text>
          <text wx:if="{{item.originalPrice > item.salePrice}}" class="price-original">¥{{item.originalPriceText}}</text>
        </view>
        <button
          class="btn btn-primary buy-btn"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
          data-price="{{item.salePrice}}"
          data-count="{{item.raceCount}}"
          bindtap="onBuyPackage"
        >立即购买</button>
      </view>
    </view>
  </view>

  <!-- ===== 空状态 ===== -->
  <view wx:if="{{!loading && empty}}" class="empty-state">
    <text class="empty-icon">📦</text>
    <text class="empty-title">暂无可购买的参赛包</text>
    <text class="empty-desc">赛事运营团队正在准备新的参赛包，请稍后再来</text>
  </view>

  <!-- ===== 加载中 ===== -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="spinner"></view>
  </view>

  <!-- ===== 底部兜底：邀请助力 ===== -->
  <view wx:if="{{!loading && !empty}}" class="invite-footer" bindtap="onInviteFriend">
    <text class="invite-icon">🎁</text>
    <text class="invite-text">不想付费？邀请好友助力免费拿 →</text>
  </view>

</view>
