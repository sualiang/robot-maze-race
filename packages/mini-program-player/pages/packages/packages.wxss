/* pages/packages/packages.wxss */
/* 参赛包购买页样式 */

/* ===== 页面头部 ===== */
.page-header {
  margin-bottom: var(--spacing-lg);
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text-white);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.page-desc {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.55);
  line-height: 1.5;
}

/* ===== 参赛包列表 ===== */
.package-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-base);
}

.package-card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: var(--spacing-lg);
  overflow: hidden;
}

/* 标签 */
.pkg-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: var(--font-size-xs);
  padding: 6rpx 20rpx;
  border-radius: 0 var(--radius-base) 0 var(--radius-base);
  font-weight: bold;
}

.tag-hot {
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
}

.tag-limited {
  background: linear-gradient(135deg, #ff9800, #ffc107);
  color: #fff;
}

/* 头部 */
.pkg-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-xs);
}

.pkg-name {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text);
}

.pkg-discount-tag {
  font-size: var(--font-size-xs);
  color: #fff;
  background-color: var(--color-primary);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.pkg-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-base);
  line-height: 1.5;
}

/* 参数特征 */
.pkg-features {
  display: flex;
  gap: var(--spacing-lg);
  padding: var(--spacing-sm) var(--spacing-base);
  background-color: var(--color-bg-secondary);
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-base);
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.feature-icon {
  font-size: var(--font-size-lg);
}

.feature-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

/* 底部价格与购买 */
.pkg-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pkg-price-area {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.pkg-current-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: bold;
}

.price-number {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--color-primary);
  line-height: 1;
}

.pkg-original-price {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  text-decoration: line-through;
}

.buy-btn {
  width: 200rpx;
  height: 72rpx;
  font-size: var(--font-size-base);
  border-radius: 36rpx;
}

/* ===== 底部提示 ===== */
.page-tips {
  margin-top: var(--spacing-xl);
  padding: var(--spacing-base) var(--spacing-lg);
  background: rgba(255,255,255,0.06);
  border-radius: var(--radius-base);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.tips-title {
  font-size: var(--font-size-sm);
  font-weight: bold;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.tips-item {
  font-size: var(--font-size-xs);
  color: rgba(255,255,255,0.45);
  display: block;
  line-height: 1.8;
}

/* ===== 空状态 ===== */
.empty-state {
  padding: var(--spacing-xl) var(--spacing-base);
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  text-align: center;
  margin-bottom: var(--spacing-base);
}

.empty-title {
  font-size: var(--font-size-base);
  color: var(--color-text);
  display: block;
  text-align: center;
  margin-bottom: var(--spacing-xs);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  display: block;
  text-align: center;
}

/* ===== 加载中 ===== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: var(--font-size-base);
  color: var(--color-text-light);
}
