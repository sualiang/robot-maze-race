/* 积分抽奖 */

/* 积分头部 */
.points-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-base);
  margin-bottom: var(--space-base);
}
.points-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-sm);
}
.points-balance {
  font-size: var(--font-giant);
  font-weight: 900;
  color: var(--color-warning);
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(250, 173, 20, 0.3);
}

/* 抽奖区域 */
.lottery-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-base);
  margin-bottom: var(--space-base);
}
.lottery-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-lg);
}
.lottery-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-base);
  width: 100%;
}
.lottery-btn {
  min-width: 200rpx;
}
.lottery-multi-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.lottery-multi-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
.lottery-picker {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--color-bg-input);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-base);
  font-size: var(--font-base);
  color: var(--color-text);
}
.picker-arrow {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

/* 抽奖结果弹窗 */
.draw-result-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.draw-result-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--space-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-base);
  min-width: 400rpx;
  max-width: 600rpx;
}
.draw-result-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-warning);
}
.draw-result-item {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
}

/* 中奖记录 */
.history-section {
  margin-bottom: var(--space-xl);
}
.history-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-base);
}
.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-bg-card);
  padding: var(--space-sm) var(--space-base);
  border-radius: var(--radius-base);
}
.history-prize {
  font-size: var(--font-base);
  color: var(--color-text);
}
.history-date {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}
