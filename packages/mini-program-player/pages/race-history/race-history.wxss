/* pages/race-history/race-history.wxss */
page {
  background-color: #0f0f23;
}

.rh-container {
  padding: 20rpx 30rpx;
  min-height: 100vh;
}

/* 月份筛选栏 */
.rh-filter-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 10rpx 0 20rpx;
}

.rh-filter-btn {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
  color: #aaa;
  font-size: 24rpx;
}

.rh-filter-btn .active {
  color: #e94560;
}

.rh-filter-arrow {
  margin-left: 6rpx;
  font-size: 20rpx;
}

/* 列表 */
.rh-list {
  padding-bottom: 40rpx;
}

.rh-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.rh-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rh-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #e94560;
  line-height: 1.3;
}

.rh-date {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.rh-middle {
  display: flex;
  align-items: center;
  margin: 0 20rpx;
}

.rh-medal {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.rh-rank {
  font-size: 26rpx;
  color: #ffaa00;
  font-weight: 600;
  white-space: nowrap;
}

/* 加载中 */
.rh-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.rh-skeleton-item {
  width: 100%;
  height: 80rpx;
  margin-bottom: 12rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
}

/* 空状态 */
.rh-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.rh-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.rh-empty-text {
  font-size: 28rpx;
  color: #666;
}
