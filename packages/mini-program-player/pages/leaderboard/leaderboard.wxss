/* 排行榜 */

/* 我的排名 */
.my-rank-card {
  margin-bottom: var(--space-base);
}
.my-rank-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}
.my-rank-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
.my-rank-badge {
  font-size: var(--font-xxl);
  font-weight: 700;
}
.top3-badge {
  /* 前三名保留 emoji，不需要额外样式 */
}
.my-rank-body {
  display: flex;
  justify-content: space-around;
}
.my-rank-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
}
.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}

/* Tab */
.tabs-bar {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: var(--space-base);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  border-radius: var(--radius-base);
}
.tab-active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* 排行列表 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}
.rank-item {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-base);
}
.rank-top3 {
  /* 高亮前三的卡片背景 */
}
.rank-is-me {
  border: 1rpx solid var(--color-primary);
}
.rank-col {
  width: 64rpx;
  text-align: center;
  flex-shrink: 0;
}
.rank-medal {
  font-size: 40rpx;
}
.rank-num {
  font-size: var(--font-lg);
  color: var(--color-text-secondary);
  font-weight: 600;
}
.user-col {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: var(--space-sm);
}
.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-round);
  background: var(--color-bg-input);
}
.user-info {
  margin-left: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}
.user-name {
  font-size: var(--font-base);
  color: var(--color-text);
}
.user-name-bold {
  font-weight: 700;
  color: var(--color-primary);
}
.me-tag {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background: rgba(233, 69, 96, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}
.score-col {
  text-align: right;
  flex-shrink: 0;
}
.score-value {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
}
.score-gold { color: #ffd700; }
.score-silver { color: #c0c0c0; }
.score-bronze { color: #cd7f32; }

/* 加载更多 */
.load-more, .load-end {
  text-align: center;
  padding: var(--space-base);
  color: var(--color-text-light);
  font-size: var(--font-sm);
}
