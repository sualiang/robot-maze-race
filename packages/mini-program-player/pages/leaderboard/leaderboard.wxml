<!--
  pages/leaderboard/leaderboard.wxml - 排行榜 V2 重做
  设计基准: 750rpx | 背景 #0F172A | 卡片 #1E293B | 主色 #FF3B5C | 金色 #F59E0B
  模块1: 顶部标题栏(居中"赛季排行榜"+ 右侧"规则"按钮/弹窗)
  模块2: 我的排名卡片(金色边框 + 渐层背景)
  模块3: 榜单Tab栏(日榜/周榜/总榜)
  模块4: 排行榜列表(前三特殊展示 + 自身红色边框)
  模块5: 底部固定提示(决赛大奖)
-->
<view class="page-leaderboard">

  <!-- 整页加载遮罩 -->
  <view wx:if="{{pageLoading}}" class="loading-mask">
    <view class="spinner"></view>
  </view>

  <block wx:else>

    <!-- ============================================================ -->
    <!-- 模块1: 顶部标题栏                                             -->
    <!-- ============================================================ -->
    <view class="lb-header">
      <text class="lb-header-title">赛季排行榜</text>
      <view class="lb-header-rule" bindtap="onOpenRules">
        <text class="lb-header-rule-text">规则</text>
      </view>
    </view>

    <!-- ============================================================ -->
    <!-- 模块2: 我的排名卡片                                           -->
    <!-- ============================================================ -->
    <view wx:if="{{myRanking}}" class="my-rank-card">
      <!-- 大号排名数字 -->
      <text class="my-rank-number">第 {{myRanking.rank}} 名</text>

      <!-- 三栏数据 -->
      <view class="my-rank-stats">
        <view class="my-rank-stat-item">
          <text class="my-rank-stat-value">{{myRanking.bestScore}}</text>
          <text class="my-rank-stat-label">最佳成绩</text>
        </view>
        <view class="my-rank-stat-divider"></view>
        <view class="my-rank-stat-item">
          <text class="my-rank-stat-value">{{myRanking.races}}次</text>
          <text class="my-rank-stat-label">参赛次数</text>
        </view>
        <view class="my-rank-stat-divider"></view>
        <view class="my-rank-stat-item">
          <text class="my-rank-stat-value">{{myRanking.beatPercent}}%</text>
          <text class="my-rank-stat-label">击败玩家</text>
        </view>
      </view>

      <!-- 底部晋级提示 -->
      <text wx:if="{{gapToFinal !== null && racesToAdvance !== null}}" class="my-rank-tip">
        距离决赛入围（前20名）还差 {{gapToFinal}} 名 · 再玩{{racesToAdvance}}局有望晋级
      </text>
    </view>

    <!-- ============================================================ -->
    <!-- 模块3: 榜单Tab栏                                             -->
    <!-- ============================================================ -->
    <view class="lb-tabs-bar">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="lb-tab-item {{currentTab === item.key ? 'lb-tab-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTabChange"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- ============================================================ -->
    <!-- 模块5: 底部固定提示(决赛大奖) 固定于Tab栏上方                 -->
    <!-- ============================================================ -->
    <view class="lb-footer-bar">
      <text class="lb-footer-text">🏆 决赛大奖：价值399元机器狗模型 + 官方金牌证书</text>
    </view>

    <!-- ============================================================ -->
    <!-- 模块4: 排行榜列表                                            -->
    <!-- ============================================================ -->
    <view wx:if="{{listLoading && entries.length === 0}}" class="lb-list-skeleton">
      <view class="lb-skeleton-item"></view>
      <view class="lb-skeleton-item"></view>
      <view class="lb-skeleton-item"></view>
      <view class="lb-skeleton-item"></view>
    </view>

    <view wx:elif="{{!listLoading && entries.length > 0}}" class="lb-rank-list">

      <!-- 前三名: 特殊展示(有至少3名选手才展示) -->
      <view wx:if="{{entries.length >= 3}}" class="lb-top3-wrapper">
        <view class="lb-top3-item {{entries[1].isMe ? 'lb-is-me' : ''}}">
          <!-- 第2名 位于左侧 -->
          <view class="lb-top3-avatar-wrap">
            <image class="lb-top3-avatar" src="{{entries[1].avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
            <text class="lb-top3-medal lb-medal-silver">🥈</text>
          </view>
          <text class="lb-top3-name">{{entries[1].nickname}}</text>
          <text class="lb-top3-score lb-score-silver">{{entries[1].score}}</text>
          <text class="lb-top3-rank-label">第2名</text>
        </view>

        <view class="lb-top3-item lb-top3-center {{entries[0].isMe ? 'lb-is-me' : ''}}">
          <!-- 第1名 居中放大 -->
          <view class="lb-top3-avatar-wrap lb-top3-avatar-gold">
            <image class="lb-top3-avatar lb-top3-avatar-big" src="{{entries[0].avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
            <text class="lb-top3-medal">🥇</text>
          </view>
          <text class="lb-top3-name">{{entries[0].nickname}}</text>
          <text class="lb-top3-score lb-score-gold">{{entries[0].score}}</text>
          <text class="lb-top3-rank-label">第1名</text>
        </view>

        <view class="lb-top3-item {{entries[2].isMe ? 'lb-is-me' : ''}}">
          <!-- 第3名 位于右侧 -->
          <view class="lb-top3-avatar-wrap">
            <image class="lb-top3-avatar" src="{{entries[2].avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
            <text class="lb-top3-medal lb-medal-bronze">🥉</text>
          </view>
          <text class="lb-top3-name">{{entries[2].nickname}}</text>
          <text class="lb-top3-score lb-score-bronze">{{entries[2].score}}</text>
          <text class="lb-top3-rank-label">第3名</text>
        </view>
      </view>

      <!-- 第4名及以后: 标准列表 -->
      <view
        wx:for="{{entries}}"
        wx:key="userId"
        class="lb-rank-item {{item.rank >= 4 ? '' : 'lb-rank-hidden-top3'}} {{item.isMe ? 'lb-is-me' : ''}}"
      >
        <block wx:if="{{item.rank >= 4}}">
          <!-- 排名数字 -->
          <view class="lb-rank-num-col">
            <text class="lb-rank-num">{{item.rank}}</text>
          </view>

          <!-- 头像 -->
          <image class="lb-rank-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />

          <!-- 昵称 -->
          <view class="lb-rank-name-col">
            <text class="lb-rank-name">{{item.nickname}}</text>
          </view>

          <!-- 成绩 -->
          <view class="lb-rank-score-col">
            <text class="lb-rank-score">{{item.score}}</text>
          </view>
        </block>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="lb-load-more" bindtap="onLoadMore">
        <text>加载更多</text>
      </view>
      <view wx:else class="lb-load-end">
        <text>— 已加载全部 —</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!listLoading && entries.length === 0}}" class="empty-state">
      <text class="empty-icon">🏆</text>
      <text class="empty-title">暂无排行数据</text>
      <text class="empty-desc">赛事开启后实时更新</text>
    </view>

  </block>

  <!-- ============================================================ -->
  <!-- 规则弹窗（Modal）                                             -->
  <!-- ============================================================ -->
  <view wx:if="{{showRules}}" class="rules-mask" bindtap="onCloseRules">
    <!-- 阻止点击内容区关闭 -->
    <view class="rules-modal" catchtap="noop">
      <text class="rules-modal-title">排行榜规则</text>

      <view class="rules-item">
        <text class="rules-item-title">排名规则</text>
        <text class="rules-item-desc">{{ruleContent.rankingRule}}</text>
      </view>

      <view class="rules-item">
        <text class="rules-item-title">赛季周期</text>
        <text class="rules-item-desc">{{ruleContent.seasonCycle}}</text>
      </view>

      <view class="rules-item">
        <text class="rules-item-title">决赛奖励</text>
        <text class="rules-item-desc">{{ruleContent.finalReward}}</text>
      </view>

      <view class="rules-footer">
        <text class="rules-disclaimer">{{ruleContent.disclaimer}}</text>
      </view>

      <view class="rules-close-btn" bindtap="onCloseRules">
        <text class="rules-close-text">我知道了</text>
      </view>
    </view>
  </view>

</view>
