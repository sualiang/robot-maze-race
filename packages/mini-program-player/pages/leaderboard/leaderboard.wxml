<!-- pages/leaderboard/leaderboard.wxml -->
<!-- 排行榜：日/月/年 tab → 榜单列表 → 高亮自己 → 我的排名卡片 -->

<view class="container">
  <!-- ===== 我的排名卡片（悬浮） ===== -->
  <view wx:if="{{myRanking}}" class="my-rank-card card">
    <view class="my-rank-left">
      <text class="my-rank-label">我的排名</text>
      <view class="my-rank-num-row">
        <text class="my-rank-num">{{myRanking.rankText}}</text>
        <text class="my-rank-pct">击败 {{myRanking.percentile}}% 玩家</text>
      </view>
    </view>
    <view class="my-rank-right">
      <text class="my-rank-score-label">最佳成绩</text>
      <text class="my-rank-score">{{myRanking.scoreText}}</text>
      <text class="my-rank-count">{{myRanking.raceCount}} 次参赛</text>
    </view>
  </view>

  <!-- ===== Tab 切换 ===== -->
  <view class="tabs-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-item {{tabIndex === index ? 'tab-active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- ===== 排行榜列表 ===== -->
  <view wx:if="{{!loading && !empty}}" class="leaderboard-list">
    <view
      wx:for="{{entries}}"
      wx:key="userId"
      class="rank-item {{item.rank <= 3 ? 'rank-top3' : ''}} {{myRanking && item.userId === myRanking.userId ? 'rank-is-me' : ''}}"
    >
      <!-- 排名 -->
      <view class="rank-col {{item.rank === 1 ? 'gold' : item.rank === 2 ? 'silver' : item.rank === 3 ? 'bronze' : ''}}">
        <text wx:if="{{item.rank === 1}}">🥇</text>
        <text wx:elif="{{item.rank === 2}}">🥈</text>
        <text wx:elif="{{item.rank === 3}}">🥉</text>
        <text wx:else class="rank-num-text">{{item.rank}}</text>
      </view>

      <!-- 头像 + 昵称 -->
      <view class="user-col">
        <image class="user-avatar" src="{{item.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <text class="user-nickname">{{item.nickname}}</text>
          <text class="user-record-date">{{item.recordDate}}</text>
        </view>
      </view>

      <!-- 成绩 -->
      <view class="score-col">
        <text class="score-value">{{item.scoreText}}</text>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{hasMore}}" class="load-more">
      <text>上拉加载更多...</text>
    </view>
    <view wx:else class="load-end">
      <text>— 已加载全部 —</text>
    </view>
  </view>

  <!-- ===== 空状态 ===== -->
  <view wx:if="{{!loading && empty}}" class="empty-state">
    <text class="empty-emoji">🏆</text>
    <text class="empty-title">暂无排行数据</text>
    <text class="empty-desc">赛事开启后会实时更新排名</text>
  </view>

  <!-- ===== 加载中 ===== -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">加载中...</text>
  </view>
</view>
