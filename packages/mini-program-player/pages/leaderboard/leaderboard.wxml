<view class="page">
  <!-- 我的排名卡片 -->
  <view wx:if="{{myRanking}}" class="my-rank-card card-elevated">
    <view class="my-rank-header">
      <text class="my-rank-label">我的排名</text>
      <text class="my-rank-badge {{myRanking.rank <= 3 ? 'top3-badge' : ''}}">
        {{myRanking.rank <= 3 ? ['🥇','🥈','🥉'][myRanking.rank-1] : myRanking.rank}}
      </text>
    </view>
    <view class="my-rank-body">
      <view class="my-rank-stat">
        <text class="stat-value">{{myRanking.bestScore}}</text>
        <text class="stat-label">最佳成绩</text>
      </view>
      <view class="my-rank-stat">
        <text class="stat-value">{{myRanking.races}}</text>
        <text class="stat-label">参赛次数</text>
      </view>
      <view class="my-rank-stat">
        <text class="stat-value">{{myRanking.beatPercent}}%</text>
        <text class="stat-label">击败玩家</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{currentTab === item.key ? 'tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 排行榜列表 -->
  <view wx:if="{{!loading && entries.length > 0}}" class="rank-list">
    <view
      wx:for="{{entries}}"
      wx:key="userId"
      class="rank-item {{item.rank <= 3 ? 'rank-top3' : ''}} {{item.isMe ? 'rank-is-me' : ''}}"
    >
      <!-- 排名 -->
      <view class="rank-col">
        <text wx:if="{{item.rank === 1}}" class="rank-medal">🥇</text>
        <text wx:elif="{{item.rank === 2}}" class="rank-medal">🥈</text>
        <text wx:elif="{{item.rank === 3}}" class="rank-medal">🥉</text>
        <text wx:else class="rank-num">{{item.rank}}</text>
      </view>

      <!-- 用户信息 -->
      <view class="user-col">
        <image class="user-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-info">
          <text class="user-name {{item.isMe ? 'user-name-bold' : ''}}">{{item.nickname}}</text>
          <text wx:if="{{item.isMe}}" class="me-tag">我</text>
        </view>
      </view>

      <!-- 成绩 -->
      <view class="score-col">
        <text class="score-value {{item.rank === 1 ? 'score-gold' : item.rank === 2 ? 'score-silver' : item.rank === 3 ? 'score-bronze' : ''}}">{{item.score}}</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
      <text>加载更多</text>
    </view>
    <view wx:else class="load-end">
      <text>— 已加载全部 —</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && entries.length === 0}}" class="empty-state">
    <text class="empty-icon">🏆</text>
    <text class="empty-title">暂无排行数据</text>
    <text class="empty-desc">赛事开启后实时更新</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="spinner"></view>
  </view>
</view>
