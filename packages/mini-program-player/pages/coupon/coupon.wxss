/* 我的卡包 V2.0 - 完整重构 */
/* 设计基准 750rpx */
/* 页面背景: #0F172A, 卡片背景: #1E293B */

/* ===== 模块2: 分类Tab栏 ===== */
.coupon-tabs {
  display: flex;
  height: 80rpx;
  margin-bottom: 24rpx;
  background: transparent;
}
.coupon-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}
.coupon-tab text {
  font-size: 28rpx;
  color: #94A3B8;
}
.coupon-tab-active text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF3B5C;
}
.coupon-tab-indicator {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: #FF3B5C;
  border-radius: 2rpx;
}

/* ===== 模块3: 券列表 ===== */
.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 单券卡片 */
.coupon-card {
  display: flex;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
.coupon-card-disabled {
  opacity: 0.5;
}

/* 左侧面值区 */
.coupon-left {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-right: 1rpx dashed #334155;
  padding-right: 24rpx;
  margin-right: 24rpx;
}
.coupon-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #F59E0B;
  line-height: 1.1;
}
.coupon-amount-dim {
  color: #94A3B8;
}
.coupon-threshold {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  text-align: center;
}
.coupon-status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-top: 8rpx;
}
.coupon-status-tag.used {
  background: #334155;
  color: #94A3B8;
}
.coupon-status-tag.expired {
  background: #334155;
  color: #94A3B8;
}

/* 右侧信息区 */
.coupon-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.coupon-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
  line-height: 1.3;
}
.coupon-scope {
  font-size: 24rpx;
  color: #94A3B8;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.coupon-validity {
  font-size: 22rpx;
  color: #64748B;
}
.coupon-actions {
  margin-top: 4rpx;
}
.coupon-use-btn {
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #FF3B5C;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 26rpx;
}
.coupon-use-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}
.coupon-status-text {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 加载态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* ===== 模块4: 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-icon {
  font-size: 72rpx;
}
.empty-title {
  font-size: 28rpx;
  color: #94A3B8;
}
.empty-get-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #FF3B5C;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  margin-top: 16rpx;
}
.empty-get-btn:active {
  opacity: 0.9;
  transform: scale(0.95);
}
