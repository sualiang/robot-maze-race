/* 我的卡券 V3.5 - 4Tab 统一页面 */
/* 设计基准 750rpx, 深色主题 #0F172A */
/* 卡片背景: #1E293B, 卡片装饰: 红绿/金色双色渐变条 */

/* ===== 页面容器 ===== */
.cc-page {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
  background: #0F172A;
  box-sizing: border-box;
}

/* ===== 模块1: 页面大标题 ===== */
.cc-header {
  padding: 32rpx 0 16rpx;
}
.cc-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}
.cc-header-subtitle {
  display: block;
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

/* ===== 模块2: 分类Tab栏 ===== */
.cc-tabs {
  display: flex;
  height: 88rpx;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid #1E293B;
}
.cc-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}
.cc-tab-label {
  font-size: 26rpx;
  color: #64748B;
  transition: color 0.2s;
}
.cc-tab-active .cc-tab-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF3B5C;
}
.cc-tab-bar {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 4rpx;
  background: #FF3B5C;
  border-radius: 2rpx;
}

/* ===== 兑换记录入口 ===== */
.cc-exch-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  background: #1E293B;
  border-radius: 12rpx;
}
.cc-exch-entry:active {
  opacity: 0.7;
}
.cc-exch-entry-text {
  font-size: 26rpx;
  color: #00D4FF;
  font-weight: 500;
}
.cc-exch-entry-arrow {
  font-size: 30rpx;
  color: #64748B;
}

/* ===== 模块3: 卡券列表 ===== */
.cc-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 24rpx;
}

/* ===== 单张卡券卡片 ===== */
.cc-card {
  display: flex;
  background: #1E293B;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
  position: relative;
  transition: transform 0.15s;
}
.cc-card:active {
  transform: scale(0.98);
}

/* 禁用态（已使用/已过期） */
.cc-card-inactive {
  opacity: 0.55;
}

/* 左侧装饰渐变条 */
.cc-card-accent {
  width: 8rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #FF3B5C 0%, #F59E0B 100%);
}
/* 参赛抵扣卡：金色渐变 */
.cc-accent-gold {
  background: linear-gradient(180deg, #F59E0B 0%, #FFD700 100%);
}
.cc-accent-inactive {
  background: linear-gradient(180deg, #475569 0%, #64748B 100%);
}

/* 卡片主体 */
.cc-card-body {
  flex: 1;
  padding: 24rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 顶部行：面额 + 状态 */
.cc-card-top {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

/* 面额区 */
.cc-amount-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.cc-amount-symbol {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
  line-height: 1;
}
.cc-amount-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #F59E0B;
  line-height: 1;
}
.cc-amount-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-left: 6rpx;
}

/* 状态 tag */
.cc-status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.cc-status-active {
  background: rgba(255, 59, 92, 0.15);
  color: #FF3B5C;
}
.cc-status-inactive {
  background: #334155;
  color: #64748B;
}

/* 分割线 */
.cc-divider {
  height: 1rpx;
  background: #334155;
  margin: 12rpx 0;
}

/* ===== 信息行区域 ===== */
.cc-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cc-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.cc-info-label {
  font-size: 24rpx;
  color: #64748B;
  flex-shrink: 0;
  width: 3.5em;
}
.cc-info-value {
  font-size: 24rpx;
  color: #E2E8F0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cc-info-merchant {
  color: #00D4FF;
}
.cc-info-gold {
  color: #F59E0B;
  font-weight: 600;
}
.cc-info-tag {
  display: inline-block;
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  align-self: flex-start;
}

/* ===== 底部操作按钮 ===== */
.cc-card-action {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}
.cc-action-btn-text {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}
.cc-action-deduct {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
}
.cc-action-coupon {
  background: rgba(0, 212, 255, 0.12);
  color: #00D4FF;
}

/* ===== 加载态 ===== */
.cc-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
.cc-loading-text {
  font-size: 28rpx;
  color: #64748B;
}

/* ===== 空状态 ===== */
.cc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 12rpx;
}
.cc-empty-icon {
  font-size: 80rpx;
}
.cc-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #E2E8F0;
}
.cc-empty-desc {
  font-size: 26rpx;
  color: #64748B;
}
.cc-empty-btn {
  width: 280rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF3B5C 0%, #FF6B6B 100%);
  border-radius: 36rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 92, 0.3);
}
.cc-empty-btn:active {
  opacity: 0.85;
  transform: scale(0.95);
}
.cc-empty-btn-secondary {
  background: linear-gradient(135deg, #1E293B 0%, #334155 100%);
  color: #00D4FF;
  box-shadow: none;
  border: 2rpx solid #334155;
}
