<view class="page">

  <!-- ========== 模块1: 顶部导航栏(通过navigationBar配置) ========== -->
  <!-- 由 navigationBarTitleText 处理标题，这里跳过了 -->

  <!-- ========== 模块2: 分类Tab栏 ========== -->
  <view class="coupon-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="coupon-tab {{currentTab === item.key ? 'coupon-tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{currentTab === item.key}}" class="coupon-tab-indicator"></view>
    </view>
  </view>

  <!-- ========== 模块3: 券列表 ========== -->
  <view class="coupon-list" wx:if="{{coupons.length > 0 && !loading}}">
    <view
      wx:for="{{coupons}}"
      wx:key="id"
      class="coupon-card {{item.status === 'used' || item.status === 'expired' ? 'coupon-card-disabled' : ''}}"
    >
      <!-- 左侧: 面值数字 -->
      <view class="coupon-left">
        <text class="coupon-amount {{item.status === 'used' || item.status === 'expired' ? 'coupon-amount-dim' : ''}}">{{item.amount || item.denomination || '¥0'}}</text>
        <text class="coupon-threshold">{{item.threshold || item.use_condition || item.condition || '无门槛'}}</text>
        <text wx:if="{{item.status === 'used'}}" class="coupon-status-tag used">已使用</text>
        <text wx:elif="{{item.status === 'expired'}}" class="coupon-status-tag expired">已过期</text>
      </view>

      <!-- 右侧: 说明信息 -->
      <view class="coupon-right">
        <text class="coupon-name">{{item.name || item.title || '优惠券'}}</text>
        <text class="coupon-scope">{{item.scope || item.description || item.rule || ''}}</text>
        <text class="coupon-validity">{{item.validUntil || item.expireDate || item.expire_date || ''}}</text>
        <view class="coupon-actions">
          <view
            wx:if="{{item.status !== 'used' && item.status !== 'expired'}}"
            class="coupon-use-btn"
            data-item="{{item}}"
            bindtap="onUseCoupon"
          >去使用</view>
          <text wx:elif="{{item.status === 'used'}}" class="coupon-status-text">已使用</text>
          <text wx:elif="{{item.status === 'expired'}}" class="coupon-status-text">已过期</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载态 -->
  <view wx:elif="{{loading}}" class="loading-state">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- ========== 模块4: 空状态 ========== -->
  <view wx:elif="{{isEmpty}}" class="empty-state">
    <text class="empty-icon">🎫</text>
    <text class="empty-title">暂无可用券</text>
    <view class="empty-get-btn" bindtap="onGetCoupons">去获取</view>
  </view>

</view>
