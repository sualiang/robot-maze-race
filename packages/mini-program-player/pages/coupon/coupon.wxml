<!-- 我的卡券 V3.5 - 4Tab 统一页面 -->
<!-- Tab 0: 参赛抵扣卡 | Tab 1: 立减券 | Tab 2: 满减券 | Tab 3: 兑换券 -->
<view class="cc-page">

  <!-- ========== 模块1: 页面大标题 ========== -->
  <view class="cc-header">
    <text class="cc-header-title">我的卡券</text>
    <text class="cc-header-subtitle">查看和管理你所有的卡券</text>
  </view>

  <!-- ========== 模块2: 分类Tab栏 ========== -->
  <view class="cc-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="cc-tab {{currentTab === item.key ? 'cc-tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text class="cc-tab-label">{{item.label}}</text>
      <view wx:if="{{currentTab === item.key}}" class="cc-tab-bar"></view>
    </view>
  </view>

  <!-- ========== 兑换记录入口（仅在非 Tab0 时显示） ========== -->
  <view wx:if="{{currentTab !== 0 && cardList.length > 0}}" class="cc-exch-entry" bindtap="onExchangeRecords">
    <text class="cc-exch-entry-text">📋 兑换记录</text>
    <text class="cc-exch-entry-arrow">›</text>
  </view>

  <!-- ========== 模块3: 卡券列表 ========== -->
  <view class="cc-list" wx:if="{{cardList.length > 0 && !loading}}">

    <view
      wx:for="{{cardList}}"
      wx:key="id"
      class="cc-card {{item.status === 0 ? 'cc-card-inactive' : ''}}"
      data-item="{{item}}"
      bindtap="onCardTap"
    >
      <!-- 装饰左侧渐变：参赛抵扣卡金色，消费券红蓝 -->
      <view class="cc-card-accent {{item.status === 0 ? 'cc-accent-inactive' : (item.isDeduction ? 'cc-accent-gold' : '')}}"></view>

      <view class="cc-card-body">
        <!-- 顶部行：面额 + 状态 tag -->
        <view class="cc-card-top">
          <view class="cc-amount-area">
            <text class="cc-amount-symbol">¥</text>
            <text class="cc-amount-value">
              <block wx:if="{{item.isDeduction}}">{{item.amountYuan.toFixed(2)}}</block>
              <block wx:else>{{item.denominationYuan.toFixed(2)}}</block>
            </text>
            <text class="cc-amount-label" wx:if="{{item.isDeduction}}">参赛抵扣</text>
            <text class="cc-amount-label" wx:else>消费券</text>
          </view>
          <text class="cc-status-tag cc-status-{{item.status === 1 ? 'active' : 'inactive'}}">{{item.statusText}}</text>
        </view>

        <!-- 分割线 -->
        <view class="cc-divider"></view>

        <!-- 信息行 -->
        <view class="cc-info">
          <!-- 参赛抵扣卡（Tab 0）：显示来源 + 到期日 + 卡片说明 -->
          <block wx:if="{{item.isDeduction}}">
            <view class="cc-info-row">
              <text class="cc-info-label">类型</text>
              <text class="cc-info-value cc-info-gold">参赛抵扣卡</text>
            </view>
            <view class="cc-info-row">
              <text class="cc-info-label">来源</text>
              <text class="cc-info-value">{{item.source}}</text>
            </view>
            <view class="cc-info-row">
              <text class="cc-info-label">到期日</text>
              <text class="cc-info-value">{{item.expiresAt || '长期有效'}}</text>
            </view>
          </block>

          <!-- 立减券 / 满减券 / 兑换券（Tab 1/2/3） -->
          <block wx:else>
            <view class="cc-info-row">
              <text class="cc-info-label">商家</text>
              <text class="cc-info-value cc-info-merchant">{{item.merchantName}}</text>
            </view>
            <!-- 立减券（coupon_type=1）：无门槛 -->
            <view wx:if="{{item.couponType === 1}}" class="cc-info-row">
              <text class="cc-info-label">使用</text>
              <text class="cc-info-value cc-info-tag">无门槛立减</text>
            </view>
            <!-- 满减券（coupon_type=3）：满X减Y -->
            <view wx:elif="{{item.couponType === 3 && item.minConsumeYuan > 0}}" class="cc-info-row">
              <text class="cc-info-label">满减</text>
              <text class="cc-info-value">满¥{{item.minConsumeYuan.toFixed(2)}}减¥{{item.denominationYuan.toFixed(2)}}</text>
            </view>
            <!-- 兑换券（coupon_type=4）：显示商品描述 -->
            <view wx:elif="{{item.couponType === 4}}" class="cc-info-row">
              <text class="cc-info-label">商品</text>
              <text class="cc-info-value">{{item.description || item.name || '兑换商品'}}</text>
            </view>
            <view class="cc-info-row">
              <text class="cc-info-label">到期</text>
              <text class="cc-info-value">{{item.validEnd || '长期有效'}}</text>
            </view>
          </block>
        </view>

        <!-- 底部操作按钮 -->
        <view class="cc-card-action" wx:if="{{item.status === 1}}">
          <text class="cc-action-btn-text {{item.isDeduction ? 'cc-action-deduct' : 'cc-action-coupon'}}">
            {{item.isDeduction ? '立即使用 ›' : '查看券码 ›'}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 加载态 ========== -->
  <view wx:elif="{{loading}}" class="cc-loading">
    <text class="cc-loading-text">加载中...</text>
  </view>

  <!-- ========== 空状态（按 Tab 显示不同提示） ========== -->
  <view wx:elif="{{isEmpty && !loading}}" class="cc-empty">
    <block wx:if="{{currentTab === 0}}">
      <text class="cc-empty-icon">🏆</text>
      <text class="cc-empty-title">暂无参赛抵扣卡</text>
      <text class="cc-empty-desc">购买参赛包即可获得参赛抵扣卡</text>
      <view class="cc-empty-btn" bindtap="onGetCards">去购买参赛包 →</view>
    </block>
    <block wx:elif="{{currentTab === 1}}">
      <text class="cc-empty-icon">🎫</text>
      <text class="cc-empty-title">暂无立减券</text>
      <text class="cc-empty-desc">购买参赛包可获赠商家立减券</text>
      <view class="cc-empty-btn cc-empty-btn-secondary" bindtap="onGetCards">去购买参赛包 →</view>
    </block>
    <block wx:elif="{{currentTab === 3}}">
      <text class="cc-empty-icon">🏪</text>
      <text class="cc-empty-title">暂无满减券</text>
      <text class="cc-empty-desc">购买参赛包可获赠商家满减券</text>
      <view class="cc-empty-btn cc-empty-btn-secondary" bindtap="onGetCards">去购买参赛包 →</view>
    </block>
    <block wx:elif="{{currentTab === 4}}">
      <text class="cc-empty-icon">🎁</text>
      <text class="cc-empty-title">暂无兑换券</text>
      <text class="cc-empty-desc">购买参赛包可获赠商家兑换券</text>
      <view class="cc-empty-btn cc-empty-btn-secondary" bindtap="onGetCards">去购买参赛包 →</view>
    </block>
  </view>

</view>
