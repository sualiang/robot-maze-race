<!-- pages/orders/orders.wxml - 我的订单 -->
<view class="page">
  <nav-bar title="我的订单" />
  <view class="header">
    <text class="header-title">我的订单</text>
  </view>

  <scroll-view class="month-tabs" scroll-x="true" enhanced show-scrollbar="{{false}}">
    <view class="month-tabs-inner">
      <view
        wx:for="{{monthOptions}}"
        wx:key="value"
        class="month-tab {{selectedMonth === item.value ? 'month-tab-active' : ''}}"
        data-month="{{item.value}}"
        bindtap="onSelectMonth"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <view class="order-list">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card">
        <view class="order-top">
          <text class="order-package">{{item.package_name}}</text>
          <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="order-info">
          <text class="order-label">订单号</text>
          <text class="order-value">{{item.order_no}}</text>
        </view>
        <view class="order-info">
          <text class="order-label">金额</text>
          <text class="order-value order-amount">¥{{item.amount_text}}</text>
        </view>
        <view wx:if="{{item.has_points_deduction}}" class="order-info">
          <text class="order-label">积分抵扣</text>
          <text class="order-value order-discount">-¥{{item.points_deduction_text}}</text>
        </view>
        <view class="order-info">
          <text class="order-label">购买时间</text>
          <text class="order-value">{{item.created_at}}</text>
        </view>
        <view wx:if="{{item.paid_at}}" class="order-info">
          <text class="order-label">支付时间</text>
          <text class="order-value">{{item.paid_at}}</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{orders.length === 0 && loaded}}" class="empty">
    <text class="empty-text">暂无订单</text>
    <text class="empty-sub">当前月份暂无订单记录</text>
  </view>

  <view wx:if="{{!loaded}}" class="loading">
    <text>加载中...</text>
  </view>
</view>
