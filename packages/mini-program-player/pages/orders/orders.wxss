/* pages/orders/orders.wxss - 我的订单 */
.page {
  padding: 20rpx;
  min-height: 100vh;
  background: #0f0f23;
  box-sizing: border-box;
}

.header {
  padding: 20rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-filter {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 32rpx;
}
.filter-label {
  font-size: 24rpx;
  color: #aaa;
}
.filter-arrow {
  font-size: 18rpx;
  color: #888;
}

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}
.picker-panel {
  width: 100%;
  background: #1a1a2e;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx 30rpx 50rpx;
}
.month-picker {
  width: 100%;
  height: 300rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
}
.picker-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.picker-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}
.picker-btn-clear {
  background: rgba(255,255,255,0.06);
  color: #aaa;
}
.picker-btn-confirm {
  background: #e94560;
  color: #fff;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 24rpx;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-package {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-paid {
  color: #4ade80;
  background: rgba(74, 222, 128, 0.1);
}
.status-pending {
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.1);
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8rpx 0;
}

.order-label {
  font-size: 24rpx;
  color: #888;
}

.order-value {
  font-size: 24rpx;
  color: #ccc;
}

.order-amount {
  color: #e94560;
  font-weight: 600;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #555;
}

.loading {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
  color: #666;
  font-size: 28rpx;
}
