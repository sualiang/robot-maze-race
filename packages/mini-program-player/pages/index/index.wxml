<!-- pages/index/index.wxml -->
<!-- 首页：品牌 + 扫码 + 参赛状态 + 参赛包 + 上次记录 -->

<view class="container">

  <!-- ===== 1. 全宽 Banner ===== -->
  <view class="hero-banner" bindtap="onScanCode">
    <image class="hero-img" src="/assets/images/hero-banner.png" mode="widthFix"/>
    <view class="hero-overlay">
      <view class="hero-scan-btn">
        <text class="hero-scan-text">扫码参赛</text>
      </view>
    </view>
  </view>

  <!-- ===== 赛季信息 + 等级标签（条件显示） ===== -->
  <view wx:if="{{seasonName}}" class="season-tag">
    <text class="season-name">{{seasonName}}</text>
    <view wx:if="{{levelName}}" class="level-badge">
      <text class="level-badge-text">{{levelName}}</text>
    </view>
    <view wx:if="{{expPercent > 0}}" class="level-exp-bar">
      <view class="level-exp-fill" style="width: {{expPercent}}%"></view>
    </view>
  </view>

  <!-- ===== 2. 剩余参赛次数（居中） ===== -->
  <view class="remain-card">
    <view class="remain-body">
      <text class="remain-label">剩余参赛次数</text>
      <text class="remain-count">{{remainCount}}</text>
      <text class="remain-unit">次</text>
    </view>
  </view>

  <!-- ===== 3. 次数不足（仅剩余次数为0时显示，位于参赛包推荐之前） ===== -->
  <view wx:if="{{remainCount === 0}}" class="no-count-card" bindtap="goToPackages">
    <text class="no-count-icon">⚡</text>
    <text class="no-count-title">次数不足</text>
    <text class="no-count-desc">购买参赛包获取参赛机会</text>
  </view>

  <!-- ===== 4. 参赛包推荐 ===== -->
  <view wx:if="{{showPackageSection}}" class="packages-section">
    <view class="section-header">
      <text class="section-title">参赛包推荐</text>
      <text class="section-more" bindtap="goToPackages">查看全部 ›</text>
    </view>
    <scroll-view class="packages-scroll" scroll-x enhanced show-scrollbar="{{false}}" enable-flex>
      <view
        wx:for="{{recommendList}}"
        wx:key="id"
        class="package-item"
        data-id="{{item.id}}"
        bindtap="onPackageTap"
      >
        <view class="package-card">
          <text class="pkg-name">{{item.name}}</text>
          <view class="pkg-bottom">
            <text class="pkg-price">{{item.salePriceText}}元</text>
            <text wx:if="{{item.times > 0}}" class="pkg-times">{{item.times}}次</text>
          </view>
          <text wx:if="{{item.tag}}" class="pkg-tag tag-{{item.tagType}}">{{item.tag}}</text>
        </view>
      </view>
    </scroll-view>
  </view>



</view>
