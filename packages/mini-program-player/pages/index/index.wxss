/* 旧顶部导航栏 - 保留样式但 wxml 里已不再使用 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #0F172A;
}
.top-nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.top-nav-venue {
  display: flex;
  align-items: center;
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
}
.top-nav-venue-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}
.top-nav-venue-name {
  font-size: 24rpx;
  color: #94A3B8;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* pages/index/index.wxss - 首页 V2重构版 */
/* 设计规范: 基准750rpx，深色主题 #0F172A */

/* ===== 页面容器 ===== */
.container {
  padding: 0 24rpx 48rpx;
  min-height: 100vh;
  background: #0F172A;
  box-sizing: border-box;
}

/* ============================================================ */
/* 自定义导航栏 - 首页 fixed，左logo右赛场名 */
/* ============================================================ */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #0F172A;
}
.custom-nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: 100rpx;
}
.custom-nav-logo {
  position: absolute;
  left: 32rpx;
  top: 150rpx;
  width: 280rpx;
  height: 74rpx;
  display: block;
  flex-shrink: 0;
}
.custom-nav-venue {
  font-size: 22rpx;
  color: #94A3B8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 260rpx;
  flex-shrink: 1;
  margin-left: auto;
}

/* ============================================================ */
/* 模块1: 顶部导航栏 （页面内容区用，不动） */
/* ============================================================ */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 30rpx;
  padding: 0 32rpx;
  margin: 0 -32rpx;
  background: transparent;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  flex: 1;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.nav-coupon-icon {
  width: 32rpx;
  height: 32rpx;
}

.nav-coupon-text {
  font-size: 24rpx;
  color: #E2E8F0;
}

/* ============================================================ */
/* 模块2: 主视觉Banner */
/* ============================================================ */
.hero-banner-image {
  position: relative;
  width: 100%;
  margin: 24rpx auto;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1E293B;
}

.hero-banner-img {
  width: 100%;
  display: block;
}

.hero-btn-wrap {
  position: absolute;
  bottom: 16rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 2;
}

.hero-btn {
  width: 240rpx;
  height: 72rpx;
  background: #FF3B5C;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255,102,0,0.4);
}

.hero-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.hero-btn-disabled {
  background: #94A3B8;
  opacity: 0.5;
}

.hero-btn-disabled:active {
  transform: none;
  opacity: 0.5;
}

.hero-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ============================================================ */
/* 模块3: 参赛状态&福利总览卡 */
/* ============================================================ */
.status-card {
  width: 100%;
  background: #1E293B;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  overflow: hidden;
  margin: 0 auto 24rpx;
}

.status-card-body {
  display: flex;
  align-items: flex-start;
  padding: 32rpx;
}

.status-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-left: 32rpx;
}

.status-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.status-number-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.status-number-red {
  font-size: 56rpx;
  font-weight: 700;
  color: #FF3B5C;
  line-height: 1;
}

.status-number-gold {
  font-size: 56rpx;
  font-weight: 700;
  color: #F59E0B;
  line-height: 1;
}

.status-unit {
  font-size: 28rpx;
  color: #94A3B8;
}

.status-arrow {
  font-size: 32rpx;
  color: #475569;
  margin-left: auto;
}

.status-subtext {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 2rpx;
}

.status-divider {
  width: 1rpx;
  height: 100rpx;
  background: #334155;
  margin: 0 24rpx;
}

.status-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  background: rgba(255, 59, 92, 0.1);
}

.status-tip-text {
  font-size: 22rpx;
  color: #FF3B5C;
}

/* ============================================================ */
/* 模块4: 今日专属福利条 - 跑马灯滚动 */
/* ============================================================ */
.promo-bar {
  width: 100%;
  height: 72rpx;
  background: #FF3B5C;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  margin: 0 auto 24rpx;
  overflow: hidden;
}

.promo-bar:active {
  opacity: 0.9;
}

.promo-marquee {
  display: flex;
  flex-shrink: 0;
  animation: promo-scroll 12s linear infinite;
}

.promo-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  white-space: nowrap;
  flex-shrink: 0;
}

.promo-text-copy {
  /* 第二份用于无缝衔接 */
}

@keyframes promo-scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* ============================================================ */
/* 模块5: 参赛包推荐区 */
/* ============================================================ */
.packages-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.section-more-text {
  font-size: 26rpx;
  color: #FF3B5C;
}

.section-more-arrow {
  font-size: 26rpx;
  color: #FF3B5C;
}

.packages-scroll {
  white-space: nowrap;
  overflow-x: scroll;
  padding-bottom: 8rpx;
}

.package-item {
  display: inline-block;
  width: 320rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.package-item:last-child {
  margin-right: 0;
}

.package-card {
  background: #1E293B;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.pkg-tag {
  display: inline-block;
  background: #FF3B5C;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  align-self: flex-start;
}

.pkg-tag-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

.pkg-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pkg-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.pkg-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #FF3B5C;
  line-height: 1;
}

.pkg-original-price {
  font-size: 24rpx;
  color: #475569;
  text-decoration: line-through;
}

.pkg-times {
  font-size: 22rpx;
  color: #94A3B8;
  margin-left: 6rpx;
}

.pkg-benefit-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.pkg-benefit-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.pkg-benefit-text {
  font-size: 24rpx;
  color: #94A3B8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pkg-buy-btn {
  width: 100%;
  height: 72rpx;
  background: #FF3B5C;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.pkg-buy-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.pkg-buy-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.packages-empty {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
  background: #1E293B;
  border-radius: 24rpx;
}

.packages-empty-text {
  font-size: 28rpx;
  color: #475569;
}

/* ============================================================ */
/* 模块6: 赛季竞技入口卡片 */
/* ============================================================ */
.season-card {
  width: 686rpx;
  background: #1E293B;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.season-card:active {
  opacity: 0.85;
}

.season-card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.season-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.season-card-subtitle {
  font-size: 24rpx;
  color: #94A3B8;
}

.season-card-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.season-card-rank {
  font-size: 28rpx;
  color: #F59E0B;
  white-space: nowrap;
}

.season-card-arrow {
  font-size: 28rpx;
  color: #475569;
}


