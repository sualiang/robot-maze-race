/* pages/index/index.wxss */
/* 赛事首页样式 */

/* ===== Hero Banner ===== */
.hero-banner {
  position: relative;
  width: 100%;
  height: 420rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-base);
}

.hero-bg {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(26,26,46,0.2) 0%, rgba(26,26,46,0.75) 100%);
  padding: var(--spacing-lg);
}

.hero-tag {
  font-size: var(--font-size-xs);
  color: rgba(255,255,255,0.85);
  background: rgba(233,69,96,0.4);
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: var(--spacing-sm);
  backdrop-filter: blur(4rpx);
}

.hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: var(--spacing-xs);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: var(--font-size-base);
  color: rgba(255,255,255,0.8);
}

/* ===== 统计数据 ===== */
.stats-row {
  margin-bottom: var(--spacing-base);
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--spacing-lg) var(--spacing-sm);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background-color: var(--color-border);
}

.arena-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-size-lg);
  font-weight: bold;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-open {
  color: var(--color-success);
}
.status-open .status-dot {
  background-color: var(--color-success);
  box-shadow: 0 0 8rpx var(--color-success);
}

.status-closed {
  color: var(--color-danger);
}
.status-closed .status-dot {
  background-color: var(--color-danger);
}

/* 我的参赛次数 */
.race-count-card {
  margin-top: var(--spacing-sm);
  padding: var(--spacing-base) var(--spacing-lg);
  background: linear-gradient(135deg, #e94560, #533483);
}

.race-count-label {
  font-size: var(--font-size-base);
  color: rgba(255,255,255,0.9);
  font-weight: bold;
}

.race-count-tip {
  font-size: var(--font-size-xs);
  color: rgba(255,255,255,0.65);
  margin-top: 4rpx;
}

.race-count-value {
  font-size: 64rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* ===== 公告 ===== */
.notice-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-base);
  margin-bottom: var(--spacing-lg);
}

.notice-icon {
  font-size: var(--font-size-lg);
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 分区标题 ===== */
.section-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-white);
  margin-bottom: var(--spacing-base);
  padding-left: var(--spacing-sm);
  border-left: 6rpx solid var(--color-primary);
}

/* ===== 快捷入口 ===== */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-sm);
  transition: transform 0.15s;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-sm);
}

.icon-race { background: linear-gradient(135deg, #e94560, #ff6b81); }
.icon-package { background: linear-gradient(135deg, #ff9800, #ffc107); }
.icon-rank { background: linear-gradient(135deg, #4caf50, #8bc34a); }
.icon-help { background: linear-gradient(135deg, #2196f3, #64b5f6); }

.action-emoji {
  font-size: 40rpx;
}

.action-name {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* ===== 赛事亮点 ===== */
.intro-list {
  margin-bottom: var(--spacing-lg);
}

.intro-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-base);
}

.intro-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.intro-content {
  flex: 1;
}

.intro-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
}

.intro-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* ===== 底部 ===== */
.page-footer {
  text-align: center;
  padding: var(--spacing-xl) 0;
}

.footer-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}
