/* pages/index/index.wxss */
/* 首页样式 — 深色主题，扫码主入口 */

/* ===== 页面容器 ===== */
.container {
  padding: 0 24rpx 24rpx;
  min-height: 100vh;
  background: #0f0f23;
  box-sizing: border-box;
}

/* ===== 1. Hero Banner ===== */
.hero-banner {
  position: relative;
  margin: 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 0 20rpx rgba(233,69,96,0.15);
}

.hero-img {
  width: 100%;
  display: block;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 6rpx 0 14rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.hero-scan-btn {
  background: rgba(233,69,96,0.88);
  border: 1px solid rgba(233,69,96,0.4);
  border-radius: 36rpx;
  padding: 6rpx 36rpx;
  box-shadow: 0 0 14rpx rgba(233,69,96,0.25);
}

.hero-scan-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

/* ===== 赛季信息标签（从接口读取） ===== */
.season-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  margin: 16rpx 0 0;
  background: rgba(83, 52, 131, 0.15);
  border-radius: 12rpx;
  border: 1rpx solid rgba(83, 52, 131, 0.3);
}
.season-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #a78bfa;
}
.level-badge {
  background: linear-gradient(135deg, #e94560, #ff6b81);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
}
.level-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}
.level-exp-bar {
  width: 160rpx;
  height: 6rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 3rpx;
  overflow: hidden;
}
.level-exp-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ffd700);
  border-radius: 3rpx;
}

/* ===== 2. 剩余参赛次数卡（主视觉） ===== */
.remain-card {
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 16rpx;
  padding: 28rpx 0;
  margin: 28rpx 0;
  border: 1rpx solid rgba(233,69,96,0.15);
}

.remain-body {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.remain-label {
  font-size: 30rpx;
  color: #c0c0d0;
  font-weight: 500;
}

.remain-count {
  font-size: 56rpx;
  font-weight: 900;
  color: #e94560;
  line-height: 1;
  text-shadow: 0 0 12rpx rgba(233,69,96,0.3);
}

.remain-unit {
  font-size: 30rpx;
  color: #a0a0b0;
  display: flex;
  align-items: center;
}

/* ===== 3. 推荐参赛包 ===== */
.packages-section {
  margin: 56rpx 0 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #e0e0e0;
}

.section-more {
  font-size: 22rpx;
  color: #e94560;
}

.packages-scroll {
  height: 176rpx;
  white-space: nowrap;
  overflow-x: scroll;
}

.package-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.package-card {
  background: #1a1a2e;
  border-radius: 14rpx;
  padding: 16rpx;
  height: 156rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.pkg-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #e0e0e0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pkg-bottom {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.pkg-price {
  font-size: 30rpx;
  font-weight: 800;
  color: #e94560;
}

.pkg-times {
  font-size: 24rpx;
  color: #888;
}

.pkg-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  align-self: flex-start;
}

.tag-hot {
  background: rgba(233,69,96,0.2);
  color: #e94560;
}

.tag-rec {
  background: rgba(76,175,80,0.2);
  color: #4caf50;
}

/* ===== 4. 次数不足（轻量提示） ===== */
.no-count-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(233,69,96,0.06);
  border: 1rpx solid rgba(233,69,96,0.15);
  border-radius: 12rpx;
  padding: 14rpx 0;
  margin: 28rpx 0;
}

.no-count-icon {
  font-size: 22rpx;
}

.no-count-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #e94560;
}

.no-count-desc {
  font-size: 20rpx;
  color: #6b7280;
}


