<view class="page">
  <!-- 顶部用户积分 + 兑换记录入口 -->
  <view class="user-points-bar">
    <view class="points-left">
      <text class="points-label">我的积分</text>
      <text class="points-value">{{userPoints}}</text>
      <text class="points-unit">分</text>
    </view>
    <view class="points-right" bindtap="onShowRecords">
      <text class="records-btn-text">兑换记录 ›</text>
    </view>
  </view>

  <!-- 商品列表（一行一个） -->
  <view class="section" wx:if="{{items.length > 0}}">
    <view class="item-list">
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="item-card"
        data-id="{{item.id}}"
        bindtap="onExchange"
      >
        <view class="card-image-area">
          <image wx:if="{{item.image}}" class="card-image" src="{{item.image}}" mode="aspectFit" />
          <view class="card-type-badge" style="background:{{item._badgeColor}}">{{item._badgeText}}</view>
        </view>
        <view class="card-info">
          <text class="card-name">{{item.name}}</text>
          <text class="card-desc">{{item.description || ''}}</text>
          <view class="card-points-badge">
            <text class="card-points-num">{{item.needPoints}}</text>
            <text class="card-points-label">积分</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{items.length === 0}}" class="empty-state">
    <text class="empty-icon">🛍️</text>
    <text class="empty-title">积分商城</text>
    <text class="empty-desc">暂无兑换商品</text>
  </view>

  <!-- 兑换确认弹窗 -->
  <view class="modal-mask {{showConfirm ? 'modal-show' : ''}}" bindtap="onCloseConfirm"></view>
  <view class="modal {{showConfirm ? 'modal-show' : ''}}">
    <view class="modal-content">
      <text class="modal-title">确认兑换</text>
      <text class="modal-body" wx:if="{{targetItem}}">使用 <text class="highlight">{{targetItem.needPoints}}</text> 积分兑换</text>
      <text class="modal-body" wx:if="{{targetItem}}">{{targetItem.name}}</text>
      <text class="modal-body" wx:if="{{targetItem && targetItem.description}}">{{targetItem.description}}</text>
    </view>
    <view class="modal-btns">
      <button class="modal-btn modal-btn-cancel" bindtap="onCloseConfirm">取消</button>
      <button class="modal-btn modal-btn-confirm" bindtap="onConfirmExchange" loading="{{exchanging}}" disabled="{{exchanging}}">确认兑换</button>
    </view>
  </view>

  <!-- 兑换记录弹窗 -->
  <view class="modal-mask {{showRecords ? 'modal-show' : ''}}" bindtap="onCloseRecords"></view>
  <view class="records-modal {{showRecords ? 'modal-show' : ''}}">
    <view class="records-modal-hd">
      <text class="records-modal-title">兑换记录</text>
      <picker mode="date" fields="month" value="{{recordMonthFilter}}" bindchange="onFilterMonth">
        <view class="records-filter-btn">{{recordMonthFilter || '按月份筛选'}} ▼</view>
      </picker>
    </view>
    <scroll-view scroll-y class="records-list" wx:if="{{records.length > 0}}">
      <view wx:for="{{records}}" wx:key="id" class="records-item">
        <view class="records-item-info">
          <text class="records-item-name">{{item.itemName}}</text>
          <text class="records-item-time">{{item.createdAt}}</text>
        </view>
        <text class="records-item-points">-{{item.spentPoints}}分</text>
      </view>
    </scroll-view>
    <view wx:else class="records-empty">
      <text>暂无兑换记录</text>
    </view>
    <view class="records-close-btn" bindtap="onCloseRecords">关闭</view>
  </view>

  <!-- toast -->
  <view class="toast {{toastMsg ? 'toast-show' : ''}}">{{toastMsg}}</view>

  <!-- 实物礼品详情浮层 -->
  <view class="fullscreen-mask {{showDetail ? 'modal-show' : ''}}" bindtap="onCloseDetail"></view>
  <view class="detail-panel {{showDetail ? 'modal-show' : ''}}">
    <view class="detail-close" bindtap="onCloseDetail">✕</view>
    <image wx:if="{{detailItem && detailItem.image}}" class="detail-image" src="{{detailItem.image}}" mode="aspectFit" />
    <view class="detail-body" wx:if="{{detailItem}}">
      <text class="detail-name">{{detailItem.name}}</text>
      <text class="detail-desc" wx:if="{{detailItem.description}}">{{detailItem.description}}</text>
      <view class="detail-points">
        <text class="detail-points-num">{{detailItem.needPoints}}</text>
        <text class="detail-points-label">积分</text>
      </view>
      <view class="detail-reminder">
        <text class="detail-reminder-title">兑换提醒</text>
        <text class="detail-reminder-text">积分兑换礼品</text>
        <text class="detail-reminder-text">请前往比赛现场的礼品兑换处兑换或咨询现场工作人员！</text>
      </view>
      <button class="detail-redeem-btn" bindtap="onStartRedeem" disabled="{{userPoints < detailItem.needPoints}}">
        {{userPoints < detailItem.needPoints ? '积分不足' : '现场兑换'}}
      </button>
    </view>
  </view>

  <!-- 核销码输入浮层 -->
  <view class="fullscreen-mask {{showRedeem ? 'modal-show' : ''}}" bindtap="onCloseRedeem"></view>
  <view class="redeem-panel {{showRedeem ? 'modal-show' : ''}}">
    <view class="redeem-close" bindtap="onCloseRedeem">✕</view>
    <view class="redeem-body">
      <text class="redeem-icon">🎁</text>
      <text class="redeem-title">积分礼品现场兑换</text>
      <text class="redeem-hint">请到赛场礼品台或向现场工作人员申请兑换</text>
      <view class="redeem-input-row">
        <input class="redeem-input" type="number" maxlength="4" placeholder="请输入4位核销码" value="{{redeemCodeInput}}" bindinput="onRedeemCodeInput" focus="{{showRedeem}}" />
      </view>
      <button class="redeem-submit-btn" bindtap="onConfirmRedeem" loading="{{redeeming}}" disabled="{{redeemCodeInput.length !== 4 || redeeming}}">核销兑换</button>
    </view>
  </view>
</view>