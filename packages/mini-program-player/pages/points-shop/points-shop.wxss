/* 积分商城 */

/* 顶部积分条 */
.user-points-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #1a1a2e, #2a1a3e);
  border-radius: 0 0 32rpx 32rpx;
  margin-bottom: 24rpx;
}
.points-label {
  font-size: 28rpx;
  color: #aaa;
}
.points-value {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffd700;
  line-height: 1.1;
}
.points-unit {
  font-size: 28rpx;
  color: #ffd700;
}

/* 分区标题 */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}
.section-title {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}
.section-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
}

/* 商品格子 */
.item-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.item-card {
  width: calc(50% - 8rpx);
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-sizing: border-box;
  overflow: hidden;
}
.card-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}
.card-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}
.card-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}
.face-value {
  font-size: 24rpx;
  color: #e94560;
  font-weight: 500;
  margin-top: 4rpx;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 12rpx;
}
.card-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.card-points-icon {
  font-size: 24rpx;
}
.card-points-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-warning);
}
.exchange-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: 8rpx;
  line-height: 1.8;
}
.exchange-btn[disabled] {
  background: var(--color-bg-input);
  color: var(--color-text-light);
  opacity: 0.6;
}
.exchange-btn::after {
  border: none;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: none;
}
.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 580rpx;
  background: var(--color-bg-card);
  border-radius: 24rpx;
  z-index: 101;
  display: none;
  overflow: hidden;
}
.modal-show,
.fullscreen-mask.modal-show {
  display: block;
}
.modal.modal-show,
.records-modal.modal-show {
  display: flex;
  flex-direction: column;
}
.modal-content {
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: var(--color-text);
}
.modal-body {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.5;
}
.highlight {
  color: var(--color-warning);
  font-weight: 700;
}
.modal-btns {
  display: flex;
  border-top: 1rpx solid var(--color-border);
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  border-radius: 0;
  background: transparent;
  color: var(--color-text);
}
.modal-btn::after {
  border: none;
}
.modal-btn-cancel {
  color: var(--color-text-secondary);
  border-right: 1rpx solid var(--color-border);
}
.modal-btn-confirm {
  color: var(--color-primary);
  font-weight: 600;
}
.modal-btn[disabled] {
  opacity: 0.5;
}

/* toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 200;
  display: none;
  pointer-events: none;
}
.toast-show {
  display: block;
}

/* 兑换记录弹窗 */
.points-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.points-right {
  margin-left: auto;
}
.records-btn-text {
  font-size: 26rpx;
  color: #F59E0B;
}
.records-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 70%;
  background: var(--color-bg-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  display: none;
  flex-direction: column;
}
.records-modal.modal-show {
  display: flex;
}
.records-modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.records-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}
.records-filter-btn {
  font-size: 24rpx;
  color: #F59E0B;
  padding: 8rpx 16rpx;
  border: 1rpx solid #F59E0B;
  border-radius: 8rpx;
}
.records-list {
  flex: 1;
  padding: 16rpx 32rpx;
}
.records-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.records-item-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.records-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.records-item-name {
  font-size: 28rpx;
  color: var(--color-text);
}
.records-item-time {
  font-size: 22rpx;
  color: var(--color-text-light);
}
.records-item-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
  flex-shrink: 0;
}
.records-empty {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--color-text-light);
  font-size: 28rpx;
}
.records-close-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
  border-top: 1rpx solid var(--color-border);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* ========== 实物礼品详情浮层 ========== */
.fullscreen-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.detail-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-bg, #0f0f23);
  z-index: 210;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s ease-out;
  overflow-y: auto;
}
.detail-panel.modal-show {
  transform: translateY(0);
}
.detail-close {
  position: absolute;
  top: 24rpx; right: 24rpx;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  z-index: 5;
}
.detail-image {
  width: 100%;
  height: 560rpx;
  background: var(--color-card, #1a1a2e);
}
.detail-body {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text, #fff);
  margin-bottom: 16rpx;
  text-align: center;
}
.detail-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary, #aaa);
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.detail-points {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
  padding: 16rpx 40rpx;
  background: rgba(233, 69, 96, 0.12);
  border-radius: 40rpx;
}
.detail-points-icon {
  font-size: 32rpx;
}
.detail-points-text {
  font-size: 32rpx;
  color: #e94560;
  font-weight: 600;
}

/* 兑换提醒 */
.detail-reminder {
  width: 100%;
  padding: 24rpx 32rpx;
  background: rgba(233, 69, 96, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(233, 69, 96, 0.2);
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.detail-reminder-title {
  font-size: 28rpx;
  color: #e94560;
  font-weight: 600;
}
.detail-reminder-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #aaa);
  text-align: center;
  line-height: 1.6;
}

.detail-redeem-btn {
  width: 400rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

/* ========== 核销码输入浮层 ========== */
.redeem-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-bg, #0f0f23);
  z-index: 220;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: scale(0.9);
  opacity: 0;
  pointer-events: none;
  transition: all 0.25s ease-out;
}
.redeem-panel.modal-show {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}
.redeem-close {
  position: absolute;
  top: 24rpx; right: 24rpx;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
}
.redeem-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}
.redeem-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.redeem-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text, #fff);
  margin-bottom: 16rpx;
}
.redeem-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary, #aaa);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 48rpx;
}
.redeem-input-row {
  width: 360rpx;
  margin-bottom: 40rpx;
}
.redeem-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--color-border, #333);
  border-radius: 12rpx;
  background: var(--color-card, #1a1a2e);
  color: var(--color-text, #fff);
  font-size: 36rpx;
  text-align: center;
  letter-spacing: 16rpx;
  padding: 0 16rpx;
}
.redeem-submit-btn {
  width: 360rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}
