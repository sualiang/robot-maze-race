/* 积分商城 */

page {
  background: #f0f2f5;
}

/* 顶部积分条 */
.user-points-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  background: #fff;
  margin-bottom: 20rpx;
}
.points-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.points-label {
  font-size: 26rpx;
  color: #999;
}
.points-value {
  font-size: 56rpx;
  font-weight: 900;
  color: #e8453c;
  line-height: 1;
}
.points-unit {
  font-size: 26rpx;
  color: #e8453c;
}

/* 单列列表 */
.section {
  padding: 0 24rpx;
}
.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 商品卡片 - 横向布局 */
.item-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  padding: 20rpx;
  gap: 20rpx;
}
.item-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 左侧图片区 */
.card-image-area {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #f7f8fa;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-image {
  width: 100%;
  height: 100%;
}
.card-type-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* 右侧信息区 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.card-desc {
  font-size: 24rpx;
  color: #aaa;
  line-height: 1.4;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  min-height: 34rpx;
}
.card-points-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-top: 12rpx;
}
.card-points-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #e8453c;
  line-height: 1;
}
.card-points-label {
  font-size: 24rpx;
  color: #e8453c;
  font-weight: 500;
}

/* 弹窗 - 保持不变 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: none;
}
.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 580rpx;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  display: none;
  overflow: hidden;
}
.modal-show,
.fullscreen-mask.modal-show {
  display: block;
}
.modal.modal-show,
.records-modal.modal-show {
  display: flex;
  flex-direction: column;
}
.modal-content {
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  color: #222;
}
.modal-body {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
}
.highlight {
  color: #e8453c;
  font-weight: 700;
}
.modal-btns {
  display: flex;
  border-top: 1rpx solid #eee;
}
.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  border-radius: 0;
  background: transparent;
  color: #333;
}
.modal-btn::after {
  border: none;
}
.modal-btn-cancel {
  color: #999;
  border-right: 1rpx solid #eee;
}
.modal-btn-confirm {
  color: #e8453c;
  font-weight: 600;
}
.modal-btn[disabled] {
  opacity: 0.5;
}

/* toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 999;
  display: none;
  pointer-events: none;
}
.toast-show {
  display: block;
}

/* 兑换记录弹窗 */
.points-right {
  margin-left: auto;
}
.records-btn-text {
  font-size: 26rpx;
  color: #F59E0B;
}
.records-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 70%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  display: none;
  flex-direction: column;
}
.records-modal.modal-show {
  display: flex;
}
.records-modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #eee;
}
.records-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}
.records-filter-btn {
  font-size: 24rpx;
  color: #F59E0B;
  padding: 8rpx 16rpx;
  border: 1rpx solid #F59E0B;
  border-radius: 8rpx;
}
.records-list {
  flex: 1;
  padding: 16rpx 32rpx;
  overflow-y: auto;
  max-height: 60vh;
}
.records-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.records-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.records-item-name {
  font-size: 28rpx;
  color: #333;
}
.records-item-time {
  font-size: 22rpx;
  color: #bbb;
}
.records-item-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
  flex-shrink: 0;
}
.records-empty {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: #bbb;
  font-size: 28rpx;
}
.records-close-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #999;
  border-top: 1rpx solid #eee;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #bbb;
}

/* ========== 实物礼品详情浮层 ========== */
.fullscreen-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  display: none;
}
.fullscreen-mask.modal-show {
  display: block;
}
.detail-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #0f0f23;
  z-index: 210;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.35s ease-out;
  overflow-y: auto;
}
.detail-panel.modal-show {
  transform: translateY(0);
}
.detail-close {
  position: absolute;
  top: 24rpx; right: 24rpx;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  z-index: 5;
}
.detail-image {
  width: 100%;
  height: 560rpx;
  background: #1a1a2e;
}
.detail-body {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-align: center;
}
.detail-desc {
  font-size: 28rpx;
  color: #aaa;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.detail-points {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
  padding: 16rpx 40rpx;
  background: rgba(233, 69, 96, 0.12);
  border-radius: 40rpx;
}
.detail-points-icon {
  font-size: 32rpx;
}
.detail-points-text {
  font-size: 32rpx;
  color: #e94560;
  font-weight: 600;
}
.detail-reminder {
  width: 100%;
  padding: 24rpx 32rpx;
  background: rgba(233, 69, 96, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(233, 69, 96, 0.2);
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.detail-reminder-title {
  font-size: 28rpx;
  color: #e94560;
  font-weight: 600;
}
.detail-reminder-text {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.6;
}
.detail-redeem-btn {
  width: 400rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

/* ========== 核销码输入浮层 ========== */
.redeem-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #0f0f23;
  z-index: 220;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: scale(0.9);
  opacity: 0;
  pointer-events: none;
  transition: all 0.25s ease-out;
}
.redeem-panel.modal-show {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}
.redeem-close {
  position: absolute;
  top: 24rpx; right: 24rpx;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
}
.redeem-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}
.redeem-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.redeem-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}
.redeem-hint {
  font-size: 26rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 48rpx;
}
.redeem-input-row {
  width: 360rpx;
  margin-bottom: 40rpx;
}
.redeem-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #333;
  border-radius: 12rpx;
  background: #1a1a2e;
  color: #fff;
  font-size: 36rpx;
  text-align: center;
  letter-spacing: 16rpx;
  padding: 0 16rpx;
}
.redeem-submit-btn {
  width: 360rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e94560, #ff6b81);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}
