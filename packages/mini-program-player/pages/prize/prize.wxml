<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">奖品陈列</text>
  </view>

  <!-- 动态奖池（滚动展示） -->
  <view wx:if="{{!poolConfigured}}" class="pool-section card-elevated">
    <text class="pool-title">🏆 总奖池</text>
    <text class="pool-amount">{{poolTotal || '奖池配置加载中...'}}</text>
    <view class="pool-scroll-hint">
      <text class="pool-hint-text">奖品持续更新中</text>
    </view>
  </view>

  <!-- 奖品分类 Tab -->
  <view class="prize-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="prize-tab {{currentTab === item.key ? 'prize-tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 奖品列表 -->
  <view class="prize-list" wx:if="{{prizes.length > 0}}">
    <view wx:for="{{prizes}}" wx:key="id" class="prize-item">
      <image
        class="prize-image"
        src="{{item.imageUrl || '/assets/images/default-avatar.png'}}"
        mode="aspectFill"
        wx:if="{{item.imageUrl}}"
      />
      <view class="prize-info">
        <text class="prize-name">{{item.name || '奖品名称'}}</text>
        <text wx:if="{{item.description}}" class="prize-desc">{{item.description}}</text>
        <text wx:if="{{item.merchantName}}" class="prize-merchant">赞助商：{{item.merchantName}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">🎁</text>
    <text class="empty-title">奖品列表</text>
    <text class="empty-desc">更多精彩奖品即将上线</text>
  </view>

  <!-- 占位提示（API未就绪） -->
  <view wx:if="{{prizeApiNotReady}}" class="placeholder-note">
    <text class="placeholder-text">以上奖品数据仅为展示，实际奖品以活动公告为准</text>
  </view>
</view>
