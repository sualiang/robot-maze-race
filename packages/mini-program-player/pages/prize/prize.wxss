/* 奖品陈列 */

.page-header {
  text-align: center;
  padding: var(--space-base) 0;
}
.page-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
}

/* 奖池区域 */
.pool-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-base);
  margin-bottom: var(--space-base);
  background: linear-gradient(135deg, #1a1a2e, #2a1a3e);
  border: 2rpx solid var(--color-warning);
}
.pool-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-warning);
  margin-bottom: var(--space-sm);
}
.pool-amount {
  font-size: var(--font-huge);
  font-weight: 900;
  color: #ffd700;
  line-height: 1;
  margin-bottom: var(--space-sm);
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}
.pool-scroll-hint {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}
.pool-hint-text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

/* Tab 切换 */
.prize-tabs {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 6rpx;
  margin-bottom: var(--space-base);
}
.prize-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  border-radius: var(--radius-base);
}
.prize-tab-active {
  background: var(--color-bg-elevated);
  color: var(--color-text);
  font-weight: 600;
}

/* 奖品列表 */
.prize-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-xl);
}
.prize-item {
  width: calc(50% - 12rpx);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.prize-image {
  width: 100%;
  height: 200rpx;
  background: var(--color-bg-input);
}
.prize-info {
  padding: var(--space-sm);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.prize-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text);
}
.prize-desc {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}
.prize-merchant {
  font-size: var(--font-xs);
  color: var(--color-info);
}

/* 占位提示 */
.placeholder-note {
  text-align: center;
  padding: var(--space-base) 0;
  margin-bottom: var(--space-xl);
}
.placeholder-text {
  font-size: var(--font-xs);
  color: var(--color-text-light);
}
