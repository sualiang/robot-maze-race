.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 998;
  background: #0f0f23;
}
.nav-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
}
.nav-logo {
  position: absolute;
  left: 32rpx;
  height: 44rpx;
  width: auto;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}