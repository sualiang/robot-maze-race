/* ==================== 签到签退页样式 ==================== */

.attendance-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

/* -------- GPS 定位卡片 -------- */
.location-card {
  margin-bottom: 24rpx;
}

.location-info {
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}

.location-address {
  display: block;
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.location-coords {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  font-family: 'SF Mono', 'Menlo', monospace;
  margin-bottom: 4rpx;
}

.location-accuracy {
  display: block;
  font-size: 20rpx;
  color: var(--color-info);
}

.location-missing {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: rgba(243, 156, 18, 0.08);
  border-radius: var(--radius-sm);
}

.location-missing-text {
  font-size: var(--font-size-sm);
  color: var(--color-warning);
  flex: 1;
}

/* -------- 签到状态卡片 -------- */
.status-card {
  text-align: center;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.attendance-status-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.status-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dot-active {
  background: var(--color-success);
  box-shadow: 0 0 20rpx rgba(39, 174, 96, 0.5);
  animation: statusPulse 2s ease-in-out infinite;
}

.dot-inactive {
  background: var(--color-text-light);
}

.dot-loading {
  background: var(--color-warning);
  animation: statusPulse 1s ease-in-out infinite;
}

.status-label {
  font-size: var(--font-size-xl);
  font-weight: 600;
}

/* -------- 赛场信息 -------- */
.venue-card {
  margin-bottom: 24rpx;
}

.venue-info-grid {
  margin-top: 16rpx;
}

.venue-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-bg);
}

.venue-info-row:last-child {
  border-bottom: none;
}

.venue-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  flex-shrink: 0;
}

.venue-value {
  font-size: var(--font-size-sm);
  font-weight: 500;
  text-align: right;
  max-width: 60%;
}

.venue-highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.text-success {
  color: var(--color-success);
}

.text-danger {
  color: var(--color-danger);
}

/* -------- 考勤记录 -------- */
.records-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.records-list {
  background: var(--color-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-bg);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  width: 100rpx;
  flex-shrink: 0;
}

.record-time {
  font-size: var(--font-size-sm);
  color: var(--color-text);
  font-weight: 500;
}

.record-center {
  width: 120rpx;
  flex-shrink: 0;
}

.record-right {
  flex: 1;
  text-align: right;
  overflow: hidden;
}

.record-location {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-duration {
  font-size: 20rpx;
  color: var(--color-info);
  display: block;
  margin-top: 2rpx;
}

/* -------- 动画 -------- */
@keyframes statusPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.2); opacity: 0.7; }
}
