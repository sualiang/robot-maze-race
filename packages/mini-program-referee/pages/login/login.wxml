<!-- 裁判端小程序 - 登录页 -->
<view class="container login-page">
  <view class="login-header">
    <text class="brand-title">机器狗迷宫竞速</text>
    <text class="brand-subtitle">裁判端</text>
  </view>

  <view class="login-form card">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" value="{{phone}}" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onPhoneInput" />
    </view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" value="{{password}}" type="password" placeholder="请输入密码" bindinput="onPasswordInput" />
    </view>

    <button class="btn btn-primary btn-block btn-lg" bindtap="handleLogin" loading="{{loading}}" disabled="{{!phone || !password}}">
      登录
    </button>

    <text class="login-agreement">仅限已授权的赛事裁判使用</text>
  </view>
</view>
