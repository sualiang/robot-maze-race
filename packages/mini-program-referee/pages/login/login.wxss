/* ==================== 登录页样式 ==================== */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 64rpx 48rpx;
}

/* -------- 品牌头部 -------- */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
}

.brand-title {
  font-size: var(--font-size-xxl);
  font-weight: 800;
  color: var(--color-bg-dark);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  font-size: var(--font-size-md);
  color: var(--color-text-light);
  background: linear-gradient(135deg, var(--color-primary), #ff6b6b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 600;
}

/* -------- 状态卡片（检查中 / 待认证 / 已认证 / 被拒绝） -------- */
.status-card {
  width: 100%;
  text-align: center;
  padding: 40rpx 32rpx;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.status-desc {
  display: block;
  font-size: var(--font-size-md);
  color: var(--color-text);
  margin: 12rpx 0;
}

.status-detail {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.highlight-text {
  color: var(--color-primary);
  font-weight: 600;
}

/* 待认证 */
.pending-icon {
  animation: rotate 3s linear infinite;
}

.pending-note {
  color: var(--color-warning);
  font-weight: 500;
}

.cert-status-tag {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.status-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
}

/* 被拒绝 */
.rejected-reason {
  color: var(--color-danger);
  background: rgba(231, 76, 60, 0.08);
  padding: 16rpx;
  border-radius: var(--radius-sm);
}

.rejected-tip {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

/* 检查中 */
.checking-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.checking-desc {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-top: 8rpx;
}

/* -------- 登录按钮区 -------- */
.login-actions {
  width: 100%;
  margin-top: 32rpx;
}

.login-agreement {
  display: block;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-top: 32rpx;
  line-height: 1.6;
}

/* -------- 底部提示 -------- */
.login-footer {
  position: fixed;
  bottom: 64rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  opacity: 0.6;
}

/* -------- 动画 -------- */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
