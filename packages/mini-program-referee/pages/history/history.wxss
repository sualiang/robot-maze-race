/* ==================== 历史记录页样式 ==================== */

.history-page {
  padding: 0;
  padding-bottom: 48rpx;
}

/* -------- 顶部统计 -------- */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: var(--color-white);
  margin-bottom: 2rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-bg);
}

/* -------- 日期筛选 -------- */
.filter-section {
  padding: 16rpx 24rpx;
  background: var(--color-white);
}

.filter-picker {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}

.filter-icon {
  margin-right: 12rpx;
}

.filter-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text);
}

.filter-arrow {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* -------- 记录列表 -------- */
.records-list {
  margin-top: 16rpx;
  padding: 0 24rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--color-white);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}

.record-item:active {
  background: var(--color-bg);
}

/* 排名 */
.record-rank {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 99rpx;
  font-size: var(--font-size-xs);
  font-weight: 600;
}

.rank-top {
  background: linear-gradient(135deg, #ffd700, #ffa500);
  color: #fff;
}

.rank-normal {
  background: var(--color-bg);
  color: var(--color-text-light);
}

.rank-none {
  color: var(--color-text-light);
}

/* 信息 */
.record-info {
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.record-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.record-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-detail {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-robot {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.record-time {
  font-size: 20rpx;
  color: var(--color-text-light);
}

/* 成绩 */
.record-score {
  text-align: right;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.score-value {
  display: block;
  font-size: var(--font-size-lg);
  font-weight: 700;
  font-family: 'SF Mono', 'Menlo', monospace;
  color: var(--color-primary);
}

.score-duration {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-light);
}

/* 箭头 */
.record-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-light);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* -------- 加载更多 -------- */
.loading-more {
  text-align: center;
  padding: 32rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

.no-more {
  opacity: 0.5;
}

/* -------- 详情弹窗 -------- */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 48rpx;
  animation: fadeIn 0.2s ease-out;
}

.detail-card {
  width: 100%;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  animation: slideUp 0.3s ease-out;
}

.detail-title {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
}

.detail-grid {
  margin-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-bg);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

.detail-value {
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.detail-score {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-primary);
}

.detail-rank {
  color: var(--color-warning);
  font-weight: 600;
}

/* -------- 动画 -------- */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
