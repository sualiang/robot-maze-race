<!--
  裁判端小程序 - 比赛操作主页面
  秒表计时 · 排队列表 · 操作控制 · 超时判罚 · 异常中断
-->
<view class="container match-page">
  <!-- ==================== 秒表计时区 ==================== -->
  <view class="stopwatch-card card {{status === 'running' ? 'running' : ''}} {{isTimeoutDanger(elapsed) ? 'timeout-danger' : ''}}">
    <!-- 计时数字显示 -->
    <view class="stopwatch">
      <text class="stopwatch-time">{{formatTime(elapsed)}}</text>
      <text class="stopwatch-ms">.{{formatMs(elapsed)}}</text>
    </view>

    <!-- 超时进度条 -->
    <view wx:if="{{status === 'running' && maxTimeout > 0}}" class="timeout-bar">
      <view class="timeout-bar-inner" style="width: {{getTimeoutPercent(elapsed)}}%"></view>
    </view>

    <!-- 当前选手信息 -->
    <view wx:if="{{currentRacer && status !== 'idle'}}" class="current-runner">
      <text class="runner-name">{{currentRacer.nickname}}</text>
      <text class="runner-robot">{{currentRacer.robotName}} · 第{{currentRacer.attempt}}次</text>
    </view>

    <!-- 比赛状态标签 -->
    <view class="stopwatch-status">
      <text wx:if="{{status === 'idle'}}" class="tag tag-info">准备就绪</text>
      <text wx:elif="{{status === 'running'}}" class="tag tag-success">▶ 进行中</text>
      <text wx:elif="{{status === 'paused'}}" class="tag tag-warning">⏸ 已暂停</text>
    </view>

    <!-- 控制按钮 -->
    <view class="stopwatch-controls">
      <!-- 未开始 -->
      <button
        wx:if="{{status === 'idle'}}"
        class="btn btn-success btn-block btn-lg"
        bindtap="startRace"
        disabled="{{!currentRacer}}"
        loading="{{actionLoading}}"
      >
        ▶ 开始比赛
      </button>

      <!-- 计时中 -->
      <view wx:elif="{{status === 'running'}}" class="btn-row">
        <button class="btn btn-warning btn-lg" bindtap="pauseRace">
          ⏸ 暂停
        </button>
        <button class="btn btn-danger btn-lg" bindtap="endRace">
          ⏹ 结束
        </button>
      </view>

      <!-- 已暂停 -->
      <view wx:elif="{{status === 'paused'}}" class="btn-row">
        <button class="btn btn-success btn-lg" bindtap="startRace" loading="{{actionLoading}}">
          ▶ 继续
        </button>
        <button class="btn btn-danger btn-lg" bindtap="endRace">
          ⏹ 结束
        </button>
      </view>
    </view>

    <!-- 超时提示 -->
    <view wx:if="{{status === 'running' && maxTimeout > 0}}" class="timeout-hint">
      ⏰ 超时限制 {{maxTimeout}}秒 · 超时将自动记录
    </view>
  </view>

  <!-- ==================== 当前操作提示 ==================== -->
  <view wx:if="{{!currentRacer}}" class="empty-state" style="padding: 40rpx;">
    <text class="empty-state-icon">🎯</text>
    <text class="empty-state-text">请从排队列表中选选手上场</text>
  </view>

  <!-- ==================== 异常操作区 ==================== -->
  <view wx:if="{{currentRacer && (status === 'running' || status === 'paused')}}" class="fault-section">
    <button
      class="btn btn-outline btn-block"
      bindtap="handleMalfunction"
      loading="{{actionLoading}}"
    >
      🤖 机器狗故障 · 保留次数重新排队
    </button>
    <button
      class="btn btn-ghost btn-block btn-sm"
      bindtap="handleForfeit"
      loading="{{actionLoading}}"
    >
      🚫 选手弃赛
    </button>
  </view>

  <!-- ==================== 排队列表 ==================== -->
  <view class="queue-section">
    <view class="section-header">
      <text class="card-title">📋 排队列表</text>
      <text class="queue-count">{{queue.length}} 人</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{queue.length === 0 && !pageLoading}}" class="empty-state">
      <text class="empty-state-icon">📭</text>
      <text class="empty-state-text">暂无排队选手</text>
    </view>

    <!-- 排队列表 -->
    <view wx:else>
      <view
        wx:for="{{queue}}"
        wx:key="id"
        class="racer-item {{item.isCurrent ? 'highlight' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectRacer"
      >
        <!-- 序号 -->
        <view class="queue-index {{item.isCurrent ? 'index-current' : ''}}">
          {{item.isCurrent ? '★' : index + 1}}
        </view>

        <!-- 头像 -->
        <view class="racer-avatar">
          <image
            src="{{item.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
            lazy-load
          />
        </view>

        <!-- 信息 -->
        <view class="racer-info">
          <text class="racer-name">{{item.nickname}}</text>
          <view class="racer-detail">
            <text class="racer-robot">{{item.robotName}}</text>
            <text class="racer-attempt">第{{item.attempt}}次 · 剩{{item.remainingRaces}}次</text>
          </view>
        </view>

        <!-- 当前标记 -->
        <view wx:if="{{item.isCurrent}}" class="racer-status">
          <text class="live-dot">●</text>
          <text class="live-label">进行中</text>
        </view>

        <!-- 上场按钮 -->
        <view wx:elif="{{!item.isCurrent && status === 'idle'}}" class="racer-actions">
          <button
            class="btn btn-primary btn-sm"
            catchtap="selectRacer"
            data-id="{{item.id}}"
            disabled="{{status === 'running'}}"
          >
            上场
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== WebSocket 状态指示 ==================== -->
  <view class="ws-indicator">
    <view class="ws-dot {{wsConnected ? 'ws-online' : 'ws-offline'}}"></view>
    <text class="ws-text">{{wsConnected ? '实时连接' : '离线模式'}}</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{pageLoading}}" class="loading-mask">
    <view class="loading-spinner">加载中...</view>
  </view>
</view>
