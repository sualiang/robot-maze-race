/* ==================== 比赛操作页样式 ==================== */

.match-page {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* -------- 秒表区 -------- */
.stopwatch-card {
  text-align: center;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  transition: background-color 0.3s;
}

.stopwatch-card.running {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95), rgba(26, 26, 46, 0.85));
  color: var(--color-white);
}

.stopwatch-card.timeout-danger {
  background: linear-gradient(135deg, rgba(231, 76, 60, 0.1), rgba(26, 26, 46, 0.9));
}

.stopwatch {
  padding: 24rpx 0;
}

.stopwatch-time {
  font-size: 140rpx;
  font-weight: 200;
  font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
  color: var(--color-primary);
  letter-spacing: 4rpx;
  font-variant-numeric: tabular-nums;
}

.running .stopwatch-time {
  color: var(--color-success);
  text-shadow: 0 0 40rpx rgba(39, 174, 96, 0.3);
}

.timeout-danger .stopwatch-time {
  color: var(--color-danger);
  text-shadow: 0 0 40rpx rgba(231, 76, 60, 0.4);
  animation: blink 0.5s ease-in-out infinite alternate;
}

.stopwatch-ms {
  font-size: var(--font-size-xl);
  color: var(--color-text-light);
  font-variant-numeric: tabular-nums;
}

.running .stopwatch-ms {
  color: rgba(255, 255, 255, 0.6);
}

/* 超时进度条 */
.timeout-bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
  margin: 16rpx 0;
  overflow: hidden;
}

.timeout-bar-inner {
  height: 100%;
  background: var(--color-success);
  border-radius: 3rpx;
  transition: width 0.1s linear, background-color 0.3s;
}

.timeout-danger .timeout-bar-inner {
  background: var(--color-danger);
}

/* 当前选手信息 */
.current-runner {
  margin-top: 12rpx;
}

.runner-name {
  display: block;
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.runner-robot {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.running .runner-robot {
  color: rgba(255, 255, 255, 0.5);
}

.stopwatch-status {
  margin-top: 16rpx;
}

/* 秒表控制按钮 */
.stopwatch-controls {
  margin-top: 32rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-row .btn {
  flex: 1;
}

/* 超时提示 */
.timeout-hint {
  margin-top: 16rpx;
  font-size: var(--font-size-xs);
  color: var(--color-warning);
}

.running .timeout-hint {
  color: rgba(243, 156, 18, 0.8);
}

/* -------- 异常操作区 -------- */
.fault-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

/* -------- 排队列表 -------- */
.queue-section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.queue-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  font-weight: 400;
}

/* 选手列表项 */
.racer-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-white);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.15s, box-shadow 0.15s;
}

.racer-item:active {
  transform: scale(0.98);
}

.racer-item.highlight {
  background: linear-gradient(135deg, rgba(233, 69, 96, 0.06), rgba(233, 69, 96, 0.02));
  border: 2rpx solid var(--color-primary);
  box-shadow: 0 0 20rpx rgba(233, 69, 96, 0.15);
}

/* 序号 */
.queue-index {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  font-weight: 700;
  color: var(--color-text-light);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.queue-index.index-current {
  background: var(--color-primary);
  color: var(--color-white);
  font-size: var(--font-size-lg);
}

/* 头像 */
.racer-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg);
  border: 2rpx solid var(--color-bg);
}

.racer-avatar image {
  width: 100%;
  height: 100%;
}

/* 信息 */
.racer-info {
  flex: 1;
  overflow: hidden;
  min-width: 0;
}

.racer-name {
  font-size: var(--font-size-md);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.racer-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.racer-robot {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.racer-attempt {
  font-size: var(--font-size-xs);
  color: var(--color-info);
}

.racer-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.live-dot {
  color: var(--color-success);
  font-size: 20rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.live-label {
  font-size: 18rpx;
  color: var(--color-success);
}

.racer-actions {
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* -------- WebSocket 状态指示器 -------- */
.ws-indicator {
  position: fixed;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  padding: 8rpx 24rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 99rpx;
  backdrop-filter: blur(10rpx);
}

.ws-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.ws-online {
  background: var(--color-success);
  box-shadow: 0 0 8rpx rgba(39, 174, 96, 0.6);
}

.ws-offline {
  background: var(--color-text-light);
}

.ws-text {
  font-size: 20rpx;
  color: var(--color-white);
}

/* -------- 动画 -------- */
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(1.3); }
}

@keyframes blink {
  from { opacity: 1; }
  to { opacity: 0.6; }
}
