/**
 * 裁判端小程序 - 全局样式
 * 机器狗迷宫竞速赛事
 */

/* ========== CSS 变量 ========== */
page {
  --color-primary: #e94560;
  --color-primary-dark: #c23a52;
  --color-bg: #f5f5f5;
  --color-bg-dark: #1a1a2e;
  --color-text: #333333;
  --color-text-light: #999999;
  --color-white: #ffffff;
  --color-success: #27ae60;
  --color-warning: #f39c12;
  --color-danger: #e74c3c;
  --color-info: #3498db;

  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;

  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-round: 50%;

  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: var(--font-size-md);
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* ========== 重置 ========== */
view, scroll-view, swiper, swiper-item, image, text, input, button {
  box-sizing: border-box;
}

/* ========== 通用布局 ========== */
.container {
  min-height: 100vh;
  padding: 24rpx;
}

.page-header {
  padding: 32rpx 24rpx;
  background: var(--color-bg-dark);
  color: var(--color-white);
  text-align: center;
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

/* ========== 卡片 ========== */
.card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--color-text);
}

/* ========== 按钮 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: 500;
  border: none;
  padding: 0 32rpx;
  transition: opacity 0.2s;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.85;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--color-white);
}

.btn-success {
  background: var(--color-success);
  color: var(--color-white);
}

.btn-warning {
  background: var(--color-warning);
  color: var(--color-white);
}

.btn-danger {
  background: var(--color-danger);
  color: var(--color-white);
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  background: transparent;
  color: var(--color-text-light);
}

.btn-sm {
  height: 64rpx;
  font-size: var(--font-size-sm);
  padding: 0 24rpx;
}

.btn-lg {
  height: 100rpx;
  font-size: var(--font-size-lg);
  padding: 0 48rpx;
}

.btn-block {
  width: 100%;
}

.btn-disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* ========== 表单 ========== */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-size-md);
}

/* ========== 状态标签 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
  font-size: var(--font-size-xs);
  font-weight: 500;
}

.tag-success {
  background: rgba(39, 174, 96, 0.1);
  color: var(--color-success);
}

.tag-warning {
  background: rgba(243, 156, 18, 0.1);
  color: var(--color-warning);
}

.tag-danger {
  background: rgba(231, 76, 60, 0.1);
  color: var(--color-danger);
}

.tag-info {
  background: rgba(52, 152, 219, 0.1);
  color: var(--color-info);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: var(--color-text-light);
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state-text {
  font-size: var(--font-size-sm);
}

/* ========== 加载 ========== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* ========== 秒表计时器 ========== */
.stopwatch {
  text-align: center;
  padding: 48rpx 0;
}

.stopwatch-time {
  font-size: 120rpx;
  font-weight: 300;
  font-family: 'SF Mono', 'Menlo', 'Monaco', monospace;
  color: var(--color-primary);
  letter-spacing: 4rpx;
}

.stopwatch-ms {
  font-size: var(--font-size-xl);
  color: var(--color-text-light);
}
