<!-- pages/profile/profile.wxml -->
<!-- 运营商信息页 -->

<view class="container">
  <!-- ========== 登录表单 ========== -->
  <view wx:if="{{!isLoggedIn}}" class="login-section">
    <view class="login-header flex-center flex-column">
      <text class="login-emoji">🏢</text>
      <text class="login-title">运营商登录</text>
      <text class="login-subtitle">管理您的场馆和赛事</text>
    </view>

    <view class="login-form card">
      <view class="form-group">
        <text class="form-label">手机号</text>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
      <view class="form-group">
        <text class="form-label">密码</text>
        <input
          class="form-input"
          type="password"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
      <view class="btn btn-primary" style="width:100%;margin-top:32rpx" bindtap="handleLogin">
        登录
      </view>
    </view>
  </view>

  <!-- ========== 已登录内容 ========== -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 用户信息卡片 -->
    <view class="profile-header card">
      <view class="profile-avatar">
        <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder flex-center">
          <text class="avatar-text">{{nickname.charAt(0) || '运'}}</text>
        </view>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{nickname || '运营商'}}</text>
        <text class="profile-phone">{{operatorPhone}}</text>
      </view>
      <view class="profile-badge">
        <text class="tag tag-primary">运营商</text>
      </view>
    </view>

    <!-- 当前场馆 -->
    <view class="section-title">🏟️ 当前场馆</view>
    <view class="venue-selector card flex-between" bindtap="toggleVenuePicker">
      <view class="flex-column flex-1">
        <text class="venue-current-name">{{currentVenueName || '未选择场馆'}}</text>
        <text class="venue-current-tip">点击切换场馆</text>
      </view>
      <text class="venue-arrow">›</text>
    </view>

    <!-- 场馆选择器（展开） -->
    <view wx:if="{{showVenuePicker}}" class="venue-picker">
      <view
        wx:for="{{venues}}"
        wx:key="id"
        class="venue-option {{item.id === currentVenueId ? 'venue-selected' : ''}}"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        bindtap="selectVenue"
      >
        <text class="option-name">{{item.name}}</text>
        <text wx:if="{{item.id === currentVenueId}}" class="option-check">✓</text>
      </view>
      <view wx:if="{{venues.length === 0}}" class="venue-empty">
        <text>暂未管理任何场馆</text>
      </view>
    </view>

    <!-- 场馆设置 -->
    <view class="section-title">⚙️ 场馆设置</view>
    <view class="settings-card card" bindtap="toggleSettings">
      <view class="flex-between">
        <view class="flex-column">
          <text class="settings-title">编辑场馆信息</text>
          <text class="settings-desc">修改名称、地址、迷宫配置</text>
        </view>
        <text class="settings-arrow">›</text>
      </view>
    </view>

    <!-- 设置表单（展开） -->
    <view wx:if="{{showSettings}}" class="settings-form card">
      <view class="form-group">
        <text class="form-label">场馆名称</text>
        <input
          class="form-input"
          placeholder="场馆名称"
          value="{{editVenueName}}"
          bindinput="onVenueNameInput"
        />
      </view>
      <view class="form-group">
        <text class="form-label">场馆地址</text>
        <view class="form-input-row flex-between">
          <input
            class="form-input flex-1"
            placeholder="场馆地址"
            value="{{editVenueAddress}}"
            bindinput="onVenueAddressInput"
          />
          <text class="location-btn" bindtap="chooseAddress">📍 定位</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">迷宫地图配置</text>
        <textarea
          class="form-textarea"
          placeholder='请输入迷宫配置（JSON格式，如 {"width":10,"height":10}）'
          value="{{editMazeConfig}}"
          bindinput="onMazeConfigInput"
          auto-height
          maxlength="2000"
        />
      </view>
      <view class="btn btn-primary" style="width:100%;margin-top:32rpx" bindtap="saveSettings">
        {{saving ? '保存中...' : '保存设置'}}
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="section-title" style="margin-top:48rpx">🔐 账户</view>
    <view class="card" bindtap="handleLogout">
      <view class="flex-between">
        <text class="logout-text">退出登录</text>
        <text class="text-light">›</text>
      </view>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="text-light">机器狗迷宫竞速 · 运营商端 v1.0.0</text>
    </view>
  </block>

  <!-- 安全区 -->
  <view class="safe-area-bottom"></view>
</view>
