/* pages/race-detail/race-detail.wxss */
/* 赛事详情样式 */

.container {
  min-height: 100vh;
  padding: var(--spacing-base);
  background-color: var(--color-bg);
}

/* ===== 赛事头部 ===== */
.race-header {
  background: linear-gradient(135deg, #0f3460, #1a508b);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-base);
}

.race-header-top {
  gap: var(--spacing-base);
}

.race-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: var(--spacing-xs);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.race-time {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

.race-desc-text {
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.race-desc-text text {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.race-actions {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-base);
}

.btn-action {
  flex: 1;
  height: 76rpx;
  border-radius: var(--radius-base);
  font-size: var(--font-size-base);
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-warning {
  background-color: #faad14;
  color: #ffffff;
}

.btn-success {
  background-color: #52c41a;
  color: #ffffff;
}

.btn-danger {
  background-color: #ff4d4f;
  color: #ffffff;
}

/* ===== 统计条 ===== */
.stats-bar {
  display: flex;
  justify-content: center;
  padding: var(--spacing-base) var(--spacing-lg);
  margin-bottom: var(--spacing-base);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: var(--font-size-xxl);
  font-weight: bold;
  color: var(--color-primary);
}

.stats-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ===== 分区标题 ===== */
.section-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--spacing-base);
}

/* ===== 选手列表 ===== */
.player-list {
  margin-bottom: var(--spacing-base);
}

/* 表头 */
.player-header {
  padding: var(--spacing-sm) var(--spacing-base);
  background-color: #f5f6f8;
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
}

.player-header text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: bold;
}

/* 行 */
.player-card {
  padding: var(--spacing-base);
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--color-border);
}

.player-card:last-child {
  border-bottom: none;
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
}

/* 列宽 */
.col-rank {
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.col-name {
  flex: 1;
  overflow: hidden;
}

.col-score {
  width: 120rpx;
  text-align: right;
  flex-shrink: 0;
}

.col-status {
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

.rank-medal {
  font-size: var(--font-size-lg);
}

.rank-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.player-name {
  font-size: var(--font-size-sm);
  font-weight: bold;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-id {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.score-text {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: bold;
}

/* 小标签 */
.tag-sm {
  padding: 2rpx 12rpx;
  font-size: var(--font-size-xs);
  border-radius: 12rpx;
  display: inline-block;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-base);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-base);
  opacity: 0.4;
}

.empty-text {
  color: var(--color-text-light);
  font-size: var(--font-size-sm);
}

/* ===== loading ===== */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-base) 0;
  background-color: #ffffff;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
  height: 40rpx;
}
