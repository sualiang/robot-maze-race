/* pages/races/races.wxss */
/* 赛事列表样式 */

.container {
  min-height: 100vh;
  padding: 0;
  background-color: var(--color-bg);
}

/* ===== 场馆信息 ===== */
.venue-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-base);
  background-color: var(--color-primary);
}

.venue-label {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.7);
}

.venue-name {
  font-size: var(--font-size-sm);
  color: #ffffff;
  font-weight: bold;
}

/* ===== 筛选 Tab ===== */
.tab-scroll {
  white-space: nowrap;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--color-border);
}

.tab-row {
  display: flex;
  padding: 0 var(--spacing-base);
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-base) var(--spacing-lg);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  position: relative;
  flex-shrink: 0;
}

.tab-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
  transition: width 0.2s;
}

.tab-active {
  color: var(--color-primary);
  font-weight: bold;
}

.tab-active::after {
  width: 60%;
}

/* ===== 赛事列表 ===== */
.race-list {
  padding: var(--spacing-base);
}

.race-card {
  padding: var(--spacing-lg);
}

.race-top {
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}

.race-name {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.race-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  display: block;
}

.race-desc {
  padding: var(--spacing-xs) 0;
  margin-bottom: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
}

.race-desc text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.race-bottom {
  margin-top: var(--spacing-xs);
}

.race-info {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.race-arrow {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) var(--spacing-base);
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-base);
  opacity: 0.4;
}

.empty-text {
  color: var(--color-text-light);
  font-size: var(--font-size-sm);
}

/* ===== loading ===== */
.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-base) 0;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
