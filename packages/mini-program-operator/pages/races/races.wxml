<!-- pages/races/races.wxml -->
<!-- 运营商赛事列表 -->

<view class="container">
  <!-- ========== 顶部场馆信息 ========== -->
  <view wx:if="{{isLoggedIn}}" class="venue-bar">
    <text class="venue-label">当前场馆：</text>
    <text class="venue-name">{{venueName}}</text>
  </view>

  <!-- ========== 状态筛选 Tab ========== -->
  <scroll-view class="tab-scroll" scroll-x enable-flex>
    <view class="tab-row">
      <view
        class="tab-item {{activeTab === 'all' ? 'tab-active' : ''}}"
        data-tab="all"
        bindtap="switchTab"
      >全部</view>
      <view
        class="tab-item {{activeTab === 'pending' ? 'tab-active' : ''}}"
        data-tab="pending"
        bindtap="switchTab"
      >未开始</view>
      <view
        class="tab-item {{activeTab === 'running' ? 'tab-active' : ''}}"
        data-tab="running"
        bindtap="switchTab"
      >进行中</view>
      <view
        class="tab-item {{activeTab === 'paused' ? 'tab-active' : ''}}"
        data-tab="paused"
        bindtap="switchTab"
      >已暂停</view>
      <view
        class="tab-item {{activeTab === 'finished' ? 'tab-active' : ''}}"
        data-tab="finished"
        bindtap="switchTab"
      >已结束</view>
    </view>
  </scroll-view>

  <!-- ========== 赛事列表 ========== -->
  <block wx:if="{{isLoggedIn}}">
    <view wx:if="{{races.length > 0}}" class="race-list">
      <view
        wx:for="{{races}}"
        wx:key="id"
        class="race-card card"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <view class="race-top flex-between">
          <view class="flex-column flex-1">
            <text class="race-name">{{item.name}}</text>
            <text class="race-time">🕐 {{item.timeText}}</text>
          </view>
          <view class="tag {{item.statusClass}}">
            {{item.statusText}}
          </view>
        </view>
        <view wx:if="{{item.description}}" class="race-desc">
          <text>{{item.description}}</text>
        </view>
        <view class="race-bottom flex-between">
          <text class="race-info">参赛人数：{{item.playerCount || 0}}</text>
          <text class="race-arrow">查看详情 ›</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loading}}" class="loading-wrapper">
        <text class="text-light">加载中...</text>
      </view>
      <view wx:if="{{!hasMore && races.length > 0}}" class="loading-wrapper">
        <text class="text-light">— 已加载全部 —</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{isEmpty && !loading}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无赛事</text>
      <text class="empty-sub-text text-sm" style="color:var(--color-text-light);margin-top:8rpx">
        请在管理后台创建赛事
      </text>
    </view>
  </block>

  <!-- ========== 未登录 ========== -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state safe-area-bottom">
    <text class="empty-icon">🔐</text>
    <text class="empty-text">请先登录</text>
    <view class="btn btn-primary mt-base" style="width:60%" bindtap="createRace">
      前往登录
    </view>
  </view>
</view>
