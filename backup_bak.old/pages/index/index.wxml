<view class="container">
  <view class="banner card">
    <text class="banner-title">速度 × 智慧</text>
    <text class="banner-desc">AI 机器狗穿越迷宫，用代码挑战极限</text>
  </view>
  <!-- ========== 剩余参赛次数 + 操作按钮 ========== -->
  <view wx:if="{{isLoggedIn}}" class="race-actions-row">
    <view class="race-count-mini card">
      <text class="race-count-label">剩余参赛次数</text>
      <text class="race-count-value">{{remainCount}}</text>
    </view>
    <view class="action-btns card">
      <view class="action-btn" bindtap="goToPackages">
        <text class="action-btn-icon">🎫</text>
        <text class="action-btn-text">购买参赛包</text>
      </view>
      <view class="action-btn" bindtap="goToHelp">
        <text class="action-btn-icon">🙌</text>
        <text class="action-btn-text">好友助力</text>
      </view>
    </view>
  </view>

  <!-- ========== 立即参赛 ========== -->
  <view class="race-now-btn card" bindtap="goToCheckin">
    <text class="race-now-text">立即参赛</text>
    <text class="race-now-arrow">›</text>
  </view>

  <!-- ========== 分割线 + Tab ========== -->
  <view class="section-divider">
    <view class="divider-line"></view>
    <text class="divider-title">参赛包选购区</text>
    <view class="divider-line"></view>
  </view>
  <view class="package-tabs">
    <view class="package-tab {{packageTab === 'packages' ? 'tab-active' : ''}}" bindtap="switchPackageTab" data-tab="packages">
      <text class="tab-label">参赛包</text>
    </view>
    <view class="package-tab {{packageTab === 'coupons' ? 'tab-active' : ''}}" bindtap="switchPackageTab" data-tab="coupons">
      <text class="tab-label">膨胀券</text>
      <text class="tab-badge">{{couponCount}}</text>
    </view>
  </view>

  <!-- ========== 参赛包列表 ========== -->
  <view wx:if="{{packageTab === 'packages'}}" class="packages-section">
    <view class="package-card card" wx:for="{{packages}}" wx:key="id" bindtap="buyPackage" data-id="{{item.id}}">
      <view class="package-info">
        <text class="package-name">{{item.name}}</text>
        <text class="package-desc">{{item.description}}</text>
        <view class="package-tags">
          <text class="package-tag">次数 {{item.races}}</text>
        </view>
      </view>
      <view class="package-price-area">
        <text class="package-price">¥{{item.price}}</text>
        <text class="package-buy">购买</text>
      </view>
    </view>

    <view wx:if="{{!packages || packages.length === 0}}" class="no-packages">
      <text>暂无参赛包</text>
    </view>
  </view>

  <!-- ========== 膨胀券列表 ========== -->
  <view wx:if="{{packageTab === 'coupons'}}" class="coupons-section">
    <view class="coupon-card card" wx:for="{{coupons}}" wx:key="id">
      <view class="coupon-left">
        <text class="coupon-count">×{{item.bonus_count || 1}}</text>
        <text class="coupon-name">膨胀券</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-valid">有效期至: {{formatDate(item.valid_until)}}</text>
        <text class="coupon-use-btn" bindtap="useCoupon" data-id="{{item.id}}">使用</text>
      </view>
    </view>

    <view wx:if="{{couponLoading}}" class="loading-tab">
      <text>加载中...</text>
    </view>
    <view wx:if="{{!couponLoading && (!coupons || coupons.length === 0)}}" class="no-packages">
      <text>暂无膨胀券</text>
      <text class="no-hint">参与好友助力获取膨胀券</text>
    </view>
  </view>

  <!-- ========== 底部 ========== -->
  <view class="footer">
    <text class="footer-text">铁甲快狗 - 闯关竞速赛 © 2026</text>
  </view>
  </view>
