.container {
  padding: 12rpx 24rpx;
  min-height: 100vh;
  background: #0f0f23;
  box-sizing: border-box;
}

.card {
  background: #1a1a2e;
  border-radius: 16rpx;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 40rpx 32rpx;
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}

/* 我的参赛次数 */
.race-count-card {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #e94560, #533483);
  margin-bottom: 12rpx;
}

.race-count-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.race-count-left {
  display: flex;
  flex-direction: column;
}

.race-count-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  font-weight: bold;
}

.race-count-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  margin-top: 4rpx;
}

.race-count-value {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.buy-btn {
  width: 100rpx;
  height: 40rpx;
  line-height: 40rpx;
  background: #fff;
  color: #e94560;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 20rpx;
  padding: 0;
  border: none;
  flex-shrink: 0;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.quick-action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.quick-action-emoji {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.quick-action-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #e0e0e0;
}

/* 立即参赛按钮 */
.race-now-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  margin-bottom: 24rpx;
}

.race-now-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.race-now-arrow {
  font-size: 48rpx;
  color: rgba(255,255,255,0.8);
}

/* 分割线 */
.section-divider {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255,255,255,0.1);
}

.divider-title {
  font-size: 24rpx;
  color: #888;
  margin: 0 20rpx;
  white-space: nowrap;
}

/* 参赛包列表 */
.packages-section {
  margin-bottom: 48rpx;
}

.package-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  margin-bottom: 12rpx;
}

.package-info {
  flex: 1;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #e0e0e0;
  display: block;
}

.package-desc {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
  display: block;
}

.package-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.package-tag {
  font-size: 20rpx;
  color: #e94560;
  background: rgba(233,69,96,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-coupon {
  color: #f6a623;
  background: rgba(246,166,35,0.1);
}

.package-price-area {
  text-align: right;
  margin-left: 20rpx;
}

.package-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e94560;
  display: block;
}

.package-buy {
  font-size: 22rpx;
  color: #e94560;
  margin-top: 8rpx;
  display: inline-block;
  background: rgba(233,69,96,0.1);
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.no-packages {
  text-align: center;
  padding: 60rpx 0;
  color: #888;
  font-size: 24rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #555;
}

/* Tab 切换 */
.package-tabs {
  display: flex;
  background: #1a1a2e;
  border-radius: 16rpx 16rpx 0 0;
  margin-bottom: 0;
}

.package-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-label {
  font-size: 28rpx;
  color: #888;
}

.tab-active .tab-label {
  color: #e94560;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: #e94560;
  border-radius: 2rpx;
}

.tab-badge {
  font-size: 20rpx;
  color: #fff;
  background: #e94560;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 14rpx;
  text-align: center;
  margin-left: 8rpx;
  padding: 0 6rpx;
}

/* 膨胀券列表 */
.coupons-section {
  margin-bottom: 48rpx;
}

.coupon-card {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(233,69,96,0.2);
}

.coupon-left {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.coupon-count {
  font-size: 36rpx;
  font-weight: 900;
  color: #e94560;
}

.coupon-name {
  font-size: 24rpx;
  color: #e94560;
  margin-left: 6rpx;
}

.coupon-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.coupon-valid {
  font-size: 22rpx;
  color: #888;
}

.coupon-use-btn {
  font-size: 22rpx;
  color: #fff;
  background: #e94560;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.loading-tab {
  text-align: center;
  padding: 60rpx 0;
  color: #888;
  font-size: 24rpx;
}

.no-hint {
  display: block;
  font-size: 22rpx;
  color: #555;
  margin-top: 12rpx;
}

/* 剩余参赛次数 + 操作按钮行 */
.race-actions-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.race-count-mini {
  width: 38%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  background: linear-gradient(135deg, #e94560, #533483);
}

.race-count-mini .race-count-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.race-count-mini .race-count-value {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.action-btns {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 8rpx;
  background: #1a1a2e;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.action-btn + .action-btn {
  margin-top: 6rpx;
}

.action-btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.action-btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #e0e0e0;
}

/* 立即参赛按钮 */
.race-now-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #e94560, #c23152);
  margin-bottom: 24rpx;
}

.race-now-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.race-now-arrow {
  font-size: 48rpx;
  color: rgba(255,255,255,0.8);
}
