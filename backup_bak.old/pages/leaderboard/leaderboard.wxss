/* pages/leaderboard/leaderboard.wxss */
/* 排行榜页面样式 */

/* ===== 我的排名卡片 ===== */
.my-rank-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-base);
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border: 1rpx solid rgba(233,69,96,0.3);
  border-radius: var(--radius-lg);
}

.my-rank-left {
  display: flex;
  flex-direction: column;
}

.my-rank-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-bottom: 4rpx;
}

.my-rank-num-row {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.my-rank-num {
  font-size: var(--font-size-xl);
  font-weight: 900;
  color: var(--color-primary);
}

.my-rank-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.my-rank-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.my-rank-score-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

.my-rank-score {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: #fff;
}

.my-rank-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* ===== Tab 切换 ===== */
.tabs-bar {
  display: flex;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-base);
  padding: 6rpx;
  margin-bottom: var(--spacing-base);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-size-base);
  color: var(--color-text-light);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.tab-active {
  background: var(--color-primary);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(233,69,96,0.4);
}

/* ===== 排名列表 ===== */
.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-base) var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-base);
  gap: var(--spacing-base);
}

.rank-item.rank-is-me {
  background: linear-gradient(135deg, rgba(233,69,96,0.08), rgba(83,52,131,0.08));
  border: 2rpx solid var(--color-primary);
  box-shadow: 0 0 16rpx rgba(233,69,96,0.15);
}

.rank-item.rank-top3 {
  background: linear-gradient(135deg, #fffdf5, #fffaf0);
}

/* 排名列 */
.rank-col {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.rank-col.gold {
  background: linear-gradient(135deg, #ffd700, #ffb300);
  box-shadow: 0 0 12rpx rgba(255,215,0,0.4);
}

.rank-col.silver {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
  box-shadow: 0 0 12rpx rgba(192,192,192,0.4);
}

.rank-col.bronze {
  background: linear-gradient(135deg, #cd7f32, #b8860b);
  box-shadow: 0 0 12rpx rgba(205,127,50,0.3);
}

.rank-num-text {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-secondary);
}

/* 用户列 */
.user-col {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  overflow: hidden;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--color-bg-secondary);
}

.user-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.user-nickname {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-record-date {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* 成绩列 */
.score-col {
  flex-shrink: 0;
  text-align: right;
}

.score-value {
  font-size: var(--font-size-lg);
  font-weight: 900;
  color: var(--color-primary);
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
}

.load-more text {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

.load-end {
  text-align: center;
  padding: var(--spacing-lg) 0;
}

.load-end text {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* ===== 空状态 ===== */
.empty-state {
  padding: var(--spacing-xl) var(--spacing-base);
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  text-align: center;
  margin-bottom: var(--spacing-base);
}

.empty-title {
  font-size: var(--font-size-base);
  font-weight: bold;
  color: var(--color-text);
  display: block;
  text-align: center;
  margin-bottom: var(--spacing-xs);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  display: block;
  text-align: center;
}

/* ===== 加载中 ===== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: var(--font-size-base);
  color: var(--color-text-light);
}
