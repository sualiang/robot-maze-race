<!-- pages/help/help.wxml -->
<!-- 好友助力裂变页：分享卡片、助力进度、助力按钮 -->

<view class="container">
  <!-- ===== 加载中 ===== -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- ===== 助力活动内容 ===== -->
  <block wx:if="{{!loading && activity}}">
    <!-- 头部卡片 -->
    <view class="help-hero card">
      <text class="hero-icon">🤝</text>
      <text class="hero-title">好友助力</text>
      <text class="hero-sub">邀请好友助力，免费获取参赛次数</text>
    </view>

    <!-- 目标 -->
    <view class="target-card card">
      <view class="target-header">
        <text class="target-label">助力目标</text>
        <view class="target-badge">{{activity.status === 'completed' ? '已完成' : activity.status === 'expired' ? '已过期' : '进行中'}}</view>
      </view>
      <text class="target-pkg">🎁 {{activity.targetPackageName || '参赛次数'}}</text>

      <!-- 进度条 -->
      <view class="progress-section">
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{activity.progressPercent}}%"></view>
        </view>
        <view class="progress-text-row">
          <text class="progress-current">{{activity.currentHelpCount}} 人已助力</text>
          <text class="progress-target">目标 {{activity.requiredHelpCount}} 人</text>
        </view>
      </view>
    </view>

    <!-- 助力者列表 -->
    <view wx:if="{{activity.helpers.length > 0}}" class="helpers-section card">
      <text class="section-title">已助力的好友</text>
      <view class="helpers-grid">
        <view
          wx:for="{{activity.helpers}}"
          wx:key="id"
          class="helper-item"
          data-helperid="{{item.helperId}}"
          data-helpername="{{item.helperNickname}}"
          bindtap="onViewHelper"
        >
          <image
            class="helper-avatar"
            src="{{item.helperAvatarUrl || '/assets/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <text class="helper-name">{{item.helperNickname || '好友'}}</text>
          <text class="helper-time">{{item.createdAt ? item.createdAt.slice(5) : ''}}</text>
        </view>
      </view>
    </view>

    <!-- 我是发起者 → 操作按钮 -->
    <view wx:if="{{isInitiator}}" class="action-section">
      <!-- Canvas 分享卡片预览 -->
      <view class="share-card-section card">
        <text class="section-title">分享卡片</text>
        <text class="share-tip">将下方卡片分享给好友或保存到相册发布</text>

        <canvas
          canvas-id="shareCanvas"
          id="shareCanvas"
          class="share-canvas"
          style="width: {{canvasWidth}}rpx; height: {{canvasHeight}}rpx;"
        ></canvas>

        <view class="share-btns">
          <button class="btn btn-primary share-action-btn" open-type="share">
            📤 转发给好友
          </button>
          <view class="btn btn-outline share-action-btn" bindtap="onSaveShareCard">
            💾 保存到相册
          </view>
        </view>
      </view>
    </view>

    <!-- 我是助力者 → 助力按钮 -->
    <view wx:if="{{isHelper || (!isInitiator && !isHelper)}}" class="action-section">
      <view wx:if="{{canHelp && activity.status === 'active'}}" class="help-action-card card">
        <text class="help-title">为好友助力</text>
        <text class="help-desc">
          助力好友 {{activity.firstHelperName}}
          完成目标，即可获得免费参赛次数
        </text>
        <view class="btn btn-primary help-btn" bindtap="onDoHelp">
          🤝 立即助力
        </view>
      </view>

      <view wx:elif="{{!canHelp && activity.status === 'active'}}" class="help-done-card card">
        <text class="done-icon">✅</text>
        <text class="done-title">你已为该好友助力</text>
        <text class="done-desc">感谢你的帮助！</text>
      </view>

      <view wx:elif="{{activity.status === 'completed'}}" class="help-done-card card">
        <text class="done-icon">🎉</text>
        <text class="done-title">助力已完成</text>
        <text class="done-desc">目标已达成，发起者获得奖励！</text>
      </view>

      <view wx:elif="{{activity.status === 'expired'}}" class="help-expired-card card">
        <text class="done-icon">⏰</text>
        <text class="done-title">助力已过期</text>
        <text class="done-desc">该助力活动已超过有效期</text>
      </view>
    </view>

    <!-- 有效期提示 -->
    <view wx:if="{{activity.expiresAt}}" class="expiry-tip">
      <text>有效期至 {{activity.expiresAt}}</text>
    </view>
  </block>

  <!-- ===== 加载失败 ===== -->
  <view wx:if="{{!loading && !activity}}" class="error-state">
    <text class="error-emoji">😵</text>
    <text class="error-title">加载失败</text>
    <text class="error-desc">请退出重试</text>
    <view class="btn btn-outline retry-btn" bindtap="createHelpActivity">
      重新创建
    </view>
  </view>
</view>
