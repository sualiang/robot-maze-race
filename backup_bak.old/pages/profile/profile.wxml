<!-- pages/profile/profile.wxml -->
<!-- 个人中心：头像昵称、数据面板、参赛记录/助力/优惠券 -->

<view class="container">
  <!-- ===== 未登录状态 ===== -->
  <view wx:if="{{!isLoggedIn}}" class="not-login card">
    <image class="default-avatar" src="/assets/images/default-avatar.png" mode="aspectFill" />
    <text class="login-prompt">登录后查看个人数据</text>
    <view class="btn btn-primary login-btn" bindtap="doLogin">
      微信一键登录
    </view>
  </view>

  <!-- ===== 已登录状态 ===== -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 个人资料区 -->
    <view class="profile-header card">
      <view class="profile-top">
        <image class="profile-avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="profile-info">
          <text class="profile-nickname">{{userInfo.nickname || userInfo.phone || '玩家'}}</text>
          <text class="profile-gender" wx:if="{{userInfo.gender === 1}}">♂</text>
          <text class="profile-gender" wx:elif="{{userInfo.gender === 2}}">♀</text>
          <text wx:if="{{userInfo.phone}}" class="profile-phone">{{userInfo.phone}}</text>
        </view>
        <view class="edit-btn" bindtap="onEditProfile">
          <text>✏️</text>
        </view>
      </view>
    </view>

    <!-- 数据面板 -->
    <view class="stats-row">
      <view class="stats-col card">
        <text class="stats-num">{{stats.totalRaces}}</text>
        <text class="stats-label">总参赛次数</text>
      </view>
      <view class="stats-col card">
        <text class="stats-num">{{bestScoreText}}</text>
        <text class="stats-label">最佳成绩</text>
      </view>
      <view class="stats-col card">
        <text class="stats-num">{{stats.rankCount}}</text>
        <text class="stats-label">上榜次数</text>
      </view>
    </view>

    <!-- 内容 Tab -->
    <view class="content-tabs">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="ctab-item {{tabIndex === index ? 'ctab-active' : ''}}"
        data-index="{{index}}"
        bindtap="onTabChange"
      >
        {{item.label}}
        <view wx:if="{{tabIndex === index}}" class="ctab-line"></view>
      </view>
    </view>

    <!-- 参赛记录 Tab -->
    <view wx:if="{{tabIndex === 0}}" class="tab-content">
      <view wx:if="{{!recordsLoading && !recordsEmpty}}" class="record-list">
        <view wx:for="{{raceRecords}}" wx:key="id" class="record-item card">
          <view class="record-row">
            <view class="record-left">
              <text class="record-arena">{{item.arenaName}}</text>
              <text class="record-date">{{item.createdAt}}</text>
            </view>
            <view class="record-right">
              <text class="record-score">{{item.scoreText}}</text>
              <text wx:if="{{item.rank}}" class="record-rank">第 {{item.rank}} 名</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{!recordsLoading && recordsEmpty}}" class="empty-tab">
        <text class="empty-icon">🏁</text>
        <text class="empty-text">暂无参赛记录</text>
        <text class="empty-hint">快去签到参加比赛吧</text>
      </view>
      <view wx:if="{{recordsLoading}}" class="loading-tab">
        <text>加载中...</text>
      </view>
    </view>

    <!-- 助力记录 Tab -->
    <view wx:if="{{tabIndex === 1}}" class="tab-content">
      <view wx:if="{{!helpsLoading && !helpsEmpty}}" class="help-list">
        <view
          wx:for="{{helpActivities}}"
          wx:key="id"
          class="help-item card"
          data-id="{{item.id}}"
          bindtap="goToHelpDetail"
        >
          <view class="help-row">
            <view class="help-left">
              <text class="help-pkg-name">🎁 {{item.targetPackageName}}</text>
              <text class="help-progress">
                助力进度 {{item.currentHelpCount}}/{{item.requiredHelpCount}}
              </text>
            </view>
            <view class="help-right">
              <view class="help-status-tag {{item.status === 'completed' ? 'tag-done' : item.status === 'expired' ? 'tag-expired' : 'tag-active'}}">
                {{item.status === 'active' ? '进行中' : item.status === 'completed' ? '已完成' : '已过期'}}
              </view>
              <text class="help-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{!helpsLoading && helpsEmpty}}" class="empty-tab">
        <text class="empty-icon">🤝</text>
        <text class="empty-text">暂无助力记录</text>
        <text class="empty-hint">邀请好友助力获取免费次数</text>
      </view>
      <view wx:if="{{helpsLoading}}" class="loading-tab">
        <text>加载中...</text>
      </view>
    </view>

    <!-- 膨胀记录 Tab -->
    <view wx:if="{{tabIndex === 2}}" class="tab-content">
      <view wx:if="{{!expandLoading && !expandEmpty}}" class="record-list">
        <view wx:for="{{expandRecords}}" wx:key="id" class="record-item">
          <view class="record-icon">🚀</view>
          <view class="record-info">
            <text class="record-title">购买 {{item.packageName}}</text>
            <text class="record-subtitle">膨胀券加成 +{{item.bonusCount}} 次参赛次数</text>
          </view>
          <view class="record-time">
            <text>{{item.usedAtText}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{!expandLoading && expandEmpty}}" class="empty-tab">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无膨胀记录</text>
        <text class="empty-hint">使用膨胀券后记录会显示在这里</text>
      </view>
      <view wx:if="{{expandLoading}}" class="loading-tab">
        <text>加载中...</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <view class="btn btn-ghost logout-btn" bindtap="doLogout">
        退出登录
      </view>
    </view>
  </block>

  <!-- ===== 编辑资料弹窗 ===== -->
  <view wx:if="{{showEditModal}}" class="modal-mask" bindtap="onCloseEditModal">
    <view class="modal-content" catchtap>
      <text class="modal-title">编辑资料</text>

      <!-- 头像 -->
      <view class="form-row">
        <text class="form-label">头像</text>
        <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{editForm.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        </button>
      </view>

      <!-- 昵称 -->
      <view class="form-row">
        <text class="form-label">昵称</text>
        <input class="form-input" placeholder="输入昵称" value="{{editForm.nickname}}" bindinput="onNicknameInput" maxlength="20" />
      </view>

      <!-- 手机号 -->
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="输入手机号（选填）" value="{{editForm.phone}}" bindinput="onPhoneInput" maxlength="11" />
      </view>

      <!-- 按钮 -->
      <view class="modal-btns">
        <view class="btn btn-ghost modal-cancel" bindtap="onCloseEditModal">取消</view>
        <view class="btn btn-primary modal-save" bindtap="onSubmitProfile">保存</view>
      </view>
    </view>
  </view>
</view>
