/* pages/checkin/checkin.wxss */
/* 签到排队页样式 */

/* ===== 页面头部 ===== */
.page-header {
  margin-bottom: var(--spacing-lg);
}

.page-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text-white);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.page-desc {
  font-size: var(--font-size-sm);
  color: rgba(255,255,255,0.55);
}

/* ===== idle — 扫码区 ===== */
.scan-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 480rpx;
  background: linear-gradient(135deg, #16213e, #1a1a2e);
  border: 2rpx dashed rgba(233,69,96,0.35);
  border-radius: var(--radius-lg);
  transition: all 0.2s;
}

.scan-card:active {
  transform: scale(0.98);
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #1a2a4a, #16213e);
}

.scan-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(233,69,96,0.2), transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-lg);
}

.scan-icon-big {
  font-size: 88rpx;
}

.scan-main-text {
  font-size: var(--font-size-lg);
  color: var(--color-text);
  font-weight: bold;
  margin-bottom: var(--spacing-sm);
}

.scan-hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  text-align: center;
  padding: 0 var(--spacing-lg);
}

/* 错误提示 */
.error-banner {
  margin-top: var(--spacing-base);
  padding: var(--spacing-base);
  background: rgba(255,77,79,0.1);
  border: 1rpx solid rgba(255,77,79,0.3);
  border-radius: var(--radius-base);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.error-icon {
  font-size: var(--font-size-lg);
}

.error-text {
  font-size: var(--font-size-sm);
  color: var(--color-danger);
  flex: 1;
}

.retry-btn {
  text-align: center;
  margin-top: var(--spacing-base);
  padding: var(--spacing-sm);
  font-size: var(--font-size-base);
  color: var(--color-primary);
}

/* ===== 通用状态卡片 ===== */
.status-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
  min-height: 400rpx;
  justify-content: center;
}

.status-emoji-big {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
}

.status-big-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
}

.status-mid-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.status-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
  margin-top: var(--spacing-lg);
}

.status-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-top: var(--spacing-xs);
}

/* 简易 spinner */
.spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 信息填写 ===== */
.fill-info {
  padding: var(--spacing-xl) var(--spacing-lg);
}

.fill-title {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.fill-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--spacing-lg);
}

.form-item {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: var(--color-bg-secondary);
  border-radius: var(--radius-sm);
  padding: 0 var(--spacing-base);
  font-size: var(--font-size-base);
  color: var(--color-text);
}

.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
}

.form-submit-btn {
  width: 100%;
  margin-top: var(--spacing-lg);
}

/* ===== 排队中 ===== */
.queuing-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.queue-section-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-base);
}

.queue-number-area {
  display: flex;
  align-items: baseline;
  margin-bottom: var(--spacing-lg);
}

.queue-big-num {
  font-size: 140rpx;
  font-weight: 900;
  color: var(--color-primary);
  line-height: 1;
  letter-spacing: -4rpx;
}

.queue-label-text {
  font-size: var(--font-size-xl);
  color: var(--color-primary);
  margin-left: 4rpx;
}

.queue-detail-list {
  display: flex;
  gap: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
}

.queue-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qdi-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-bottom: 4rpx;
}

.qdi-value {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
}

.queue-tip {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  margin-bottom: var(--spacing-lg);
  text-align: center;
}

.queue-actions {
  width: 100%;
  display: flex;
  justify-content: center;
}

.queue-refresh {
  width: 400rpx;
}

/* ===== 比赛中 ===== */
.racing-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.racing-hint {
  margin-top: var(--spacing-lg);
  padding: var(--spacing-sm) var(--spacing-base);
  background: rgba(233,69,96,0.08);
  border-radius: var(--radius-sm);
}

.racing-hint text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

/* ===== 已完成 ===== */
.finished-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
}

.finished-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-base);
  margin-top: var(--spacing-lg);
}

.finished-btn {
  width: 500rpx;
}

/* ===== 加载遮罩 ===== */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-overlay-text {
  font-size: var(--font-size-lg);
  color: #fff;
}
