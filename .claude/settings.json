{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx vite *)",
      "Bash(node dist/server.js *)",
      "Bash(npx ts-node-dev *)",
      "Bash(git *)",
      "Bash(mysql *)",
      "Bash(mysqld *)",
      "Bash(curl *)",
      "Bash(netstat *)",
      "Bash(tasklist *)",
      "Bash(taskkill *)",
      "Bash(cp *)",
      "Bash(rm *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(echo *)",
      "Bash(sleep *)",
      "Bash(pwd *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(start *)",
      "Bash(cd *)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:/Users/suali/robot-maze-race && git add -A && git diff --cached --stat"
          }
        ]
      }
    ]
  }
}
