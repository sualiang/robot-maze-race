# 铁甲快狗 - 环境配置模板
# 复制此文件为 .env 并填入真实值

# 数据库
DATABASE_URL=mysql://root:YOUR_DB_PASSWORD@127.0.0.1:3308/robot_maze_race
COMMON_DB_NAME=robot_maze_race_common
DB_PORT=3308

# 服务
NODE_ENV=development
PORT=3000

# JWT（生产环境必须设置为强随机字符串）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# 微信小程序
WECHAT_APPID=
WECHAT_APPSECRET=

# 微信服务号
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_MP_TOKEN=

# 微信支付
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# Redis（可选）
REDIS_URL=redis://127.0.0.1:6379

GIT_VERSION=dev-local
